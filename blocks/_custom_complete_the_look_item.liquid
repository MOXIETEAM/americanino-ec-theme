{% liquid
  assign has_products = false
  for i in (1..5)
    assign product_key = 'product_' | append: i
    assign p = block.settings[product_key]
    if p != blank
      assign has_products = true
      break
    endif
  endfor
%}

<complete-the-look-item
  class="ctl-item"
  {{ block.shopify_attributes }}
>
  {%- comment -%} ── Media (GIF / image) ── {%- endcomment -%}
  {%- if block.settings.image != blank -%}
    <img
      class="ctl-item__media"
      src="{{ block.settings.image | image_url: width: 600 }}"
      alt="{{ block.settings.image.alt | default: '' | escape }}"
      width="{{ block.settings.image.width }}"
      height="{{ block.settings.image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'ctl-item__media placeholder' }}
  {%- endif -%}

  {%- if has_products -%}
    {%- comment -%} ── "+" button — shown on hover via CSS ── {%- endcomment -%}
    <button
      class="ctl-plus-btn"
      ref="plusBtn"
      on:click="/handlePlusBtnClick"
      aria-label="Ver productos del look"
      aria-expanded="false"
      aria-haspopup="true"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="10" cy="10" r="9.5" fill="#1E1E1E" stroke="#1E1E1E"/>
        <path d="M10 4V16.625" stroke="white" stroke-width="1.5"/>
        <path d="M16.3125 10.3125L3.6875 10.3125" stroke="white" stroke-width="1.5"/>
      </svg>
    </button>

    {%- comment -%} ── Product popup (fixed, opened by JS) ── {%- endcomment -%}
    <div
      class="ctl-popup"
      ref="popup"
      role="dialog"
      aria-label="Productos del look"
      aria-modal="true"
    >
      <button
        type="button"
        class="ctl-popup-close"
        aria-label="Cerrar"
      >
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 11L4.29349 5.22741L0.399395 0H2.67927L5.52496 3.8965H5.59153L8.42058 0H10.5673L6.68986 5.21137L11 11H8.73676L5.49168 6.54227H5.39183L2.16339 11H0Z" fill="#2C2C2C"/>
        </svg>
      </button>
      <div class="ctl-popup__inner">
      <div class="ctl-popup__products">
        {%- for i in (1..5) -%}
          {%- assign product_key = 'product_' | append: i -%}
          {%- assign p = block.settings[product_key] -%}
          {%- if p != blank -%}
            {%- assign selected_variant = p.selected_or_first_available_variant -%}

            <div class="ctl-product" data-product-id="{{ p.id }}">

              {%- if p.featured_image != blank -%}
                <img
                  class="ctl-product__image"
                  src="{{ p.featured_image | image_url: width: 176 }}"
                  alt="{{ p.featured_image.alt | default: p.title | escape }}"
                  width="88"
                  height="88"
                  loading="lazy"
                >
              {%- else -%}
                <div class="ctl-product__image-placeholder" aria-hidden="true"></div>
              {%- endif -%}

              <div class="ctl-product__info">

                <p class="ctl-product__title">
                  <a href="{{ p.url }}" tabindex="-1" aria-label="{{ p.title | escape }}">{{ p.title | escape }}</a>
                </p>

                <div class="ctl-product__price">
                  {%- if selected_variant.compare_at_price > selected_variant.price -%}
                    <span class="ctl-price--compare">{{ selected_variant.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span class="ctl-price--current">{{ selected_variant.price | money }}</span>
                </div>

                {%- if p.variants.size > 1 -%}
                  <label
                    class="ctl-product__option-label"
                    for="ctl-select-{{ p.id }}-{{ block.id }}-{{ i }}"
                  >
                    {{- p.options.first -}}
                  </label>
                  <select
                    id="ctl-select-{{ p.id }}-{{ block.id }}-{{ i }}"
                    class="ctl-variant-select"
                    on:change="/handleVariantChange"
                    aria-label="{{ p.options.first | escape }}"
                  >
                    {%- for variant in p.variants -%}
                      <option
                        value="{{ variant.id }}"
                        {%- unless variant.available %} disabled{%- endunless %}
                        {%- if variant == selected_variant %} selected{%- endif %}
                      >
                        {{- variant.title -}}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}

                <button
                  class="ctl-add-btn"
                  on:click="/handleAddToCart"
                  data-variant-id="{{ selected_variant.id }}"
                  {%- unless selected_variant.available %} disabled{%- endunless %}
                  aria-label="Añadir {{ p.title | escape }} a la bolsa"
                >
                  {%- if selected_variant.available -%}
                    Añadir a la bolsa
                  {%- else -%}
                    Agotado
                  {%- endif -%}
                </button>

              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      </div>{%- comment -%} /ctl-popup__inner {%- endcomment -%}
    </div>
  {%- endif -%}

</complete-the-look-item>

{% schema %}
{
  "name": "Moxie Item",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "GIF / Imagen del modelo",
      "info": "Sube un GIF animado para reproducción continua."
    },
    {
      "type": "header",
      "content": "Productos del look (máx. 5)"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Producto 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Producto 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Producto 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Producto 4"
    },
    {
      "type": "product",
      "id": "product_5",
      "label": "Producto 5"
    }
  ]
}
{% endschema %}
