{%- comment -%} MOXIE: Bloque "Cuotas + ver bancos" para la card de producto nativa
  (PLP principal / main-collection). Mismo texto/link que en Best Sellers y
  Collection Grid, pero con su propia clase — .cg-card__cuotas depende de estar
  dentro de .cg-card (custom_product_card.liquid) y esta card usa una
  estructura nativa distinta.
{%- endcomment -%}

{%- liquid
  assign cuotas_text = block.settings.installments_text
  assign link_label = block.settings.installments_link_label
  assign link_url = block.settings.installments_link_url
-%}

{%- if cuotas_text != blank -%}
  <div class="mox-installments" {{ block.shopify_attributes }}>
    {{- cuotas_text -}}
    {%- if link_url != blank and link_label != blank -%}
      <a href="{{ link_url }}" class="mox-installments__link">{{ link_label }}</a>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .mox-installments {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2px;
    font-size: 11px;
    line-height: 1.3;
    font-weight: 400;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .mox-installments p {
    margin: 0;
  }

  .mox-installments__link {
    color: inherit;
    text-decoration: underline;
    margin-inline-start: 2px;

    &:hover {
      opacity: 0.75;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Moxie Cuotas",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "installments_text",
      "label": "Texto de cuotas",
      "default": "<p>0% de interés hasta 3 cuotas</p>",
      "info": "Deja vacío para ocultar"
    },
    {
      "type": "text",
      "id": "installments_link_label",
      "label": "Texto del enlace \"ver bancos\"",
      "default": "ver bancos",
      "info": "Deja vacío para no mostrar el enlace"
    },
    {
      "type": "url",
      "id": "installments_link_url",
      "label": "Enlace de \"ver bancos\""
    }
  ]
}
{% endschema %}
