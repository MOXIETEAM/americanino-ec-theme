

{% liquid
  assign block_settings = block.settings
  assign use_inverse_logo = false

  if section.settings.enable_transparent_header_home and template.name == 'index' and section.settings.home_color_scheme == 'inverse'
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_product and template.name == 'product' and section.settings.product_color_scheme == 'inverse'
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_collection and template.name == 'collection' and section.settings.collection_color_scheme == 'inverse'
    assign use_inverse_logo = true
  endif

  if use_inverse_logo
    if settings.logo_inverse != blank
      assign inverse_logo = settings.logo_inverse
    else
      assign inverse_logo = settings.logo
    endif
  endif

  assign alt_text_fallback = shop.name | escape | append: ' ' | append: 'accessibility.home' | t

  assign logo_h        = settings.logo_height
  assign logo_h_mobile = settings.logo_height_mobile
  if block.settings.logo_height_override > 0
    assign logo_h = block.settings.logo_height_override
  endif
  if block.settings.logo_height_mobile_override > 0
    assign logo_h_mobile = block.settings.logo_height_mobile_override
  endif
%}

{% comment %}
  Output all logo variants, use CSS to hide/show the appropriate one
  based on the .header[transparent] selector
{% endcomment %}
<a
  {% if template.name == 'index' and block_settings.hide_logo_on_home_page %}
    data-hidden-on-home-page
  {% endif %}
  href="{{ routes.root_url }}"
  class="size-style spacing-style header-logo"
  style="
    {% render 'size-style', settings: block_settings %}
    {% render 'spacing-style', settings: block_settings %}
    --font-family: var(--font-body--family);
    --font-style: var(--font-body--style);
    --font-weight: 600;
  "
  {{ block.shopify_attributes }}
>
  {% liquid
    assign logo_width = logo_h | times: settings.logo.aspect_ratio | ceil
    assign logo_width_mobile = logo_h_mobile | times: settings.logo.aspect_ratio | ceil
    assign inverse_logo_width = logo_h | times: inverse_logo.aspect_ratio | ceil
    assign inverse_logo_width_mobile = logo_h_mobile | times: inverse_logo.aspect_ratio | ceil
    assign logo_style = '--header-logo-image-width: ' | append: logo_width | append: 'px;' | append: '--header-logo-image-width-mobile: ' | append: logo_width_mobile | append: 'px; --header-logo-image-height: ' | append: logo_h | append: 'px; --header-logo-image-height-mobile: ' | append: logo_h_mobile | append: 'px;'
    assign inverse_logo_style = '--header-logo-image-width: ' | append: inverse_logo_width | append: 'px;' | append: '--header-logo-image-width-mobile: ' | append: inverse_logo_width_mobile | append: 'px; --header-logo-image-height: ' | append: logo_h | append: 'px; --header-logo-image-height-mobile: ' | append: logo_h_mobile | append: 'px;'
  %}

  <span
    class="header-logo__image-container header-logo__image-container--original"
    data-testid="header-logo"
  >
    {% render 'image',
      image: settings.logo,
      class: 'header-logo__image',
      height: logo_h,
      alt_text_fallback: alt_text_fallback,
      text_fallback: shop.name,
      style: logo_style
    %}
  </span>

  {% if use_inverse_logo %}
    <span
      class="header-logo__image-container header-logo__image-container--inverse"
      data-testid="header-logo-inverse"
    >
      {% render 'image',
        image: inverse_logo,
        class: 'header-logo__image',
        height: logo_h,
        alt_text_fallback: alt_text_fallback,
        text_fallback: shop.name,
        style: inverse_logo_style
      %}
    </span>
  {% endif %}

  {%- comment -%} MOXIE: Logo de marca (Americanino) {%- endcomment -%}
  {%- if block.settings.logo_ame != blank -%}
    {%- liquid
      assign ame_w  = logo_h | times: block.settings.logo_ame.aspect_ratio | ceil
      assign ame_wm = logo_h_mobile | times: block.settings.logo_ame.aspect_ratio | ceil
      assign ame_style = '--header-logo-image-width: ' | append: ame_w | append: 'px; --header-logo-image-width-mobile: ' | append: ame_wm | append: 'px; --header-logo-image-height: ' | append: logo_h | append: 'px; --header-logo-image-height-mobile: ' | append: logo_h_mobile | append: 'px;'
    -%}
    <span class="header-logo__image-container header-logo__image-container--brand" data-brand-logo>
      {%- render 'image', image: block.settings.logo_ame, class: 'header-logo__image', height: settings.logo_height, alt_text_fallback: alt_text_fallback, text_fallback: shop.name, style: ame_style -%}
    </span>
  {%- endif -%}

  {%- comment -%}
    MOXIE: Logo animado Americanino — máxima prioridad, reemplaza cualquier
    otro logo (imagen, marca, video) mientras esté activo. Colapsa
    "AMERICANINO®" a "AMCNO®" una sola vez al cargar (ver stylesheet/javascript
    más abajo para la animación y el fallback de prefers-reduced-motion).
  {%- endcomment -%}
  {%- if block.settings.enable_animated_logo -%}
    {%- comment -%} MOXIE: Montserrat 900 solo se carga si este logo está activo {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@900&display=swap" rel="stylesheet">
    <span
      class="header-logo__image-container header-logo__image-container--animated mox-anim-logo"
      data-animated-logo
      aria-label="{{ alt_text_fallback }}"
      style="--header-logo-image-height: {{ logo_h }}px; --header-logo-image-height-mobile: {{ logo_h_mobile }}px;"
    >
      {%- comment -%} MOXIE: sin saltos de línea entre spans a propósito — el whitespace del source se renderiza como espacio real a este tamaño de fuente y dejaba huecos donde las letras deberían colapsar {%- endcomment -%}
      <span class="mox-anim-logo__word" aria-hidden="true"><span class="mox-anim-logo__letter" data-keep style="--i: 0;">A</span><span class="mox-anim-logo__letter" data-keep style="--i: 1;">M</span><span class="mox-anim-logo__letter" style="--i: 2;">E</span><span class="mox-anim-logo__letter" style="--i: 3;">R</span><span class="mox-anim-logo__letter" style="--i: 4;">I</span><span class="mox-anim-logo__letter" data-keep style="--i: 5;">C</span><span class="mox-anim-logo__letter" style="--i: 6;">A</span><span class="mox-anim-logo__letter" style="--i: 7;">N</span><span class="mox-anim-logo__letter" style="--i: 8;">I</span><span class="mox-anim-logo__letter" data-keep style="--i: 9;">N</span><span class="mox-anim-logo__letter" data-keep style="--i: 10;">O</span></span>
      <span class="mox-anim-logo__registered" aria-hidden="true">&reg;</span>
    </span>
  {%- endif -%}

  {%- comment -%} MOXIE: Video logo — highest priority, overrides all image logos {%- endcomment -%}
  {%- if block.settings.logo_video != blank -%}
    {%- liquid
      assign video_logo_style = '--header-logo-image-height: ' | append: logo_h | append: 'px; --header-logo-image-height-mobile: ' | append: logo_h_mobile | append: 'px;'
    -%}
    <span class="header-logo__image-container header-logo__image-container--video" data-video-logo>
      <video
        class="header-logo__image header-logo__image--video"
        autoplay
        muted
        playsinline
        {% if block.settings.logo_video_loop %}loop{% endif %}
        style="{{ video_logo_style }}"
        aria-label="{{ alt_text_fallback }}"
      >
        {%- for source in block.settings.logo_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    </span>
  {%- endif -%}
</a>

{% stylesheet %}
.mox-anim-logo__word {
  display: flex;
  height: 100%;
  max-height: 100%;
}
  .header-logo {
    display: flex;
    height: 100%;
    font-size: var(--font-size--md);
    font-family: var(--font-family);
    font-weight: var(--font-weight);
    font-style: var(--font-style);
    color: var(--color-foreground);
    justify-content: center;
    align-items: center;
    text-decoration: none;

    &[data-hidden-on-home-page] {
      display: none;

      #header-component:is(
          [sticky='always']:not([data-scroll-direction='none']),
          [sticky='scroll-up'][data-scroll-direction='up']
        )
        & {
        display: flex;
      }
    }

    @media screen and (max-width: 749px) {
      padding: 0;
    }

    @media screen and (min-width: 750px) {
      flex-shrink: 0;
    }

    &:hover {
      text-decoration: none;
    }
  }

  .header-logo__image {
    object-fit: contain;
    height: var(--header-logo-image-height-mobile);
    width: var(--header-logo-image-width-mobile);

    @media screen and (min-width: 750px) {
      height: var(--header-logo-image-height);
      width: var(--header-logo-image-width);
    }
  }

  .header-logo:has(.header-logo__image-container--inverse) .header-logo__image-container--original {
    display: var(--header-logo-display, block);
  }

  .header-logo__image-container--inverse {
    display: var(--header-logo-inverse-display, none);
  }

  /* MOXIE: Oculta el logo por defecto cuando el logo de marca está activo */
  .header-logo:has([data-brand-logo]) .header-logo__image-container--original {
    display: none;
  }

  /* MOXIE: Video logo — hides all image logos when video is active */
  .header-logo:has([data-video-logo]) .header-logo__image-container--original,
  .header-logo:has([data-video-logo]) .header-logo__image-container--inverse,
  .header-logo:has([data-video-logo]) .header-logo__image-container--brand {
    display: none;
  }

  /* MOXIE: Logo animado — máxima prioridad, oculta cualquier otro logo mientras esté activo */
  .header-logo:has([data-animated-logo]) .header-logo__image-container--original,
  .header-logo:has([data-animated-logo]) .header-logo__image-container--inverse,
  .header-logo:has([data-animated-logo]) .header-logo__image-container--brand,
  .header-logo:has([data-animated-logo]) .header-logo__image-container--video {
    display: none;
  }

  .mox-anim-logo {
    display: inline-flex;
    align-items: baseline;
    /* font-family: 'Montserrat', sans-serif; */
    font-weight: 900;
    letter-spacing: 0px;
    color: #1a2744;
    line-height: 0.75;
    white-space: nowrap;
    /* MOXIE: timing exacto del diseño original (0.6s ease-out) — el
       --animation-speed del theme (0.125s) es para micro-interacciones y
       hacía que la revelación se sintiera instantánea en vez de gradual. */
    animation: mox-anim-logo-in 0.6s ease-out both;
    /* MOXIE: mismas variables que .header-logo__image, así respeta el
       "Alto desktop/Alto móvil" del bloque en vez de un tamaño fijo */
    font-size: var(--header-logo-image-height-mobile, 24px);

    @media screen and (min-width: 750px) {
      font-size: 65px;
    }
  }

  .mox-anim-logo__letter {
    display: inline-block;
    /* MOXIE: tope generoso (no recorta ninguna letra en su ancho natural)
       para poder animar max-width de forma pareja — a diferencia de width,
       max-width transiciona suave desde un número concreto; width no se
       puede animar desde "auto" (el ancho natural de un inline-block sin
       ancho fijo), así que colapsaba de golpe en vez de achicarse gradual. */
    max-width: 2em;
    /* MOXIE: 0.4s ease, igual que el original */
    transition:
      opacity 0.4s ease,
      transform 0.4s ease,
      max-width 0.4s ease,
      margin 0.4s ease;
    /* MOXIE: efecto escalonado vía transition-delay en vez de un setTimeout
       por letra — --i lo inyecta el Liquid de arriba, una sola vez, sin JS.
       Mismo delay que el original (index * 50ms). */
    transition-delay: calc(var(--i, 0) * 50ms);
  }

  /* MOXIE: [data-collapsed] lo agrega el javascript de abajo, una vez, tras
     la pausa inicial — colapsa a "AMCNO" ocultando las letras sin [data-keep] */
  .mox-anim-logo[data-collapsed] .mox-anim-logo__letter:not([data-keep]) {
    opacity: 0;
    transform: scaleX(0);
    max-width: 0;
    margin: 0;
    overflow: hidden;
    transition-delay: calc(var(--i, 0) * 50ms);
  }

  .mox-anim-logo__registered {
    /* MOXIE: mismas proporciones que el original (20px/5px a font-size 80px),
       en em para que escalen con el alto de logo configurado en el bloque */
    font-size: 0.25em;
    vertical-align: super;
    margin-left: 0.0625em;
    font-weight: 700;
  }

  @keyframes mox-anim-logo-in {
    from {
      opacity: 0;
      translate: 0 20px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mox-anim-logo {
      animation: none;
    }

    .mox-anim-logo__letter {
      transition: none;
    }
  }

  .header-logo__image--video {
    width: auto;
    height: var(--header-logo-image-height-mobile);
    max-height: var(--header-logo-image-height-mobile);
    object-fit: contain;

    @media screen and (min-width: 750px) {
      height: var(--header-logo-image-height);
      max-height: var(--header-logo-image-height);
    }

    @media (prefers-reduced-motion: reduce) {
      animation: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function playVideoLogos() {
      document.querySelectorAll('.header-logo__image--video').forEach(function (video) {
        if (video.paused) video.play().catch(function () {});
      });
    }

    // MOXIE: colapsa el logo animado Americanino ("AMERICANINO®" → "AMCNO®")
    // una sola vez por elemento — [data-anim-done] evita reprogramar el
    // timer si el theme editor re-renderiza la sección/bloque. El stagger
    // entre letras es puro CSS (transition-delay con --i), así que acá solo
    // hace falta un timer por logo, no uno por letra.
    function revealAnimatedLogos() {
      document.querySelectorAll('[data-animated-logo]:not([data-anim-done])').forEach(function (logo) {
        logo.setAttribute('data-anim-done', '');

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          logo.setAttribute('data-collapsed', '');
          return;
        }

        setTimeout(function () {
          logo.setAttribute('data-collapsed', '');
        }, 2500);
      });
    }

    function init() {
      playVideoLogos();
      revealAnimatedLogos();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Re-trigger cuando el theme editor re-renderiza la sección o el bloque
    document.addEventListener('shopify:section:load', init);
    document.addEventListener('shopify:block:select', init);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Moxie Logo",
  "tag": null,
  "class": "header-logo",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.edit_logo_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_logo_on_home_page",
      "label": "t:settings.hide_logo_on_home_page",
      "info": "t:info.hide_logo_on_home_page_help"
    },
    {
      "type": "header",
      "content": "Logo animado Americanino"
    },
    {
      "type": "paragraph",
      "content": "Reemplaza cualquier otro logo (imagen, marca o video) mientras esté activo. Anima \"AMERICANINO®\" colapsando a \"AMCNO®\" al cargar la página."
    },
    {
      "type": "checkbox",
      "id": "enable_animated_logo",
      "label": "Activar logo animado Americanino",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.padding_desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Tamaño del logo"
    },
    {
      "type": "paragraph",
      "content": "Sobreescribe el tamaño definido en Ajustes del tema. Deja en 0 para usar el valor global."
    },
    {
      "type": "range",
      "id": "logo_height_override",
      "label": "Alto desktop",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "logo_height_mobile_override",
      "label": "Alto móvil",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Logo de marca"
    },
    {
      "type": "paragraph",
      "content": "Si se configura, reemplaza el logo general del tema."
    },
    {
      "type": "image_picker",
      "id": "logo_ame",
      "label": "Logo Americanino"
    },
    {
      "type": "header",
      "content": "Logo en video"
    },
    {
      "type": "paragraph",
      "content": "Si se configura, tiene prioridad sobre cualquier logo de imagen. El video se reproduce automáticamente, sin sonido y en bucle."
    },
    {
      "type": "video",
      "id": "logo_video",
      "label": "Archivo de video"
    },
    {
      "type": "checkbox",
      "id": "logo_video_loop",
      "label": "Repetir en bucle",
      "default": false
    }
  ]
}
{% endschema %}
