{%- comment -%} MOXIE: New Arrivals — grid de productos por colección con tabs Hombre/Mujer {%- endcomment -%}

{%- liquid
  assign tab_blocks    = section.blocks | where: 'type', 'tab'
  assign show_tabs     = false
  if tab_blocks.size > 1
    assign show_tabs = true
  endif
  assign cols_desktop  = section.settings.cols_desktop
  assign cols_mobile   = section.settings.cols_mobile
  assign image_ratio   = section.settings.image_ratio
  assign padding_v     = section.settings.padding_v
  assign max_swatches  = 4
-%}

<div
  class="custom-new-arrivals custom-center-container"
  id="new-arrivals-{{ section.id }}"
  style="
    padding-block: {{ padding_v }}px;
    {%- if section.settings.bg_color != blank -%} background-color: {{ section.settings.bg_color }};{%- endif -%}
    --na-tab-color: {{ section.settings.tab_color | default: '#1a1a1a' }};
    --na-tab-active-bg: {{ section.settings.tab_active_bg | default: '#1a1a1a' }};
    --na-tab-active-text: {{ section.settings.tab_active_text | default: '#ffffff' }};
    --na-cols-desktop: {{ cols_desktop }};
    --na-cols-mobile: {{ cols_mobile }};
    --na-ratio: {{ image_ratio }};
    --cg-ratio: {{ image_ratio }};
  "
  {{ section.shopify_attributes }}
>
  <div class="na-inner custom-standar-max-width">

    {%- comment -%} ── Header ───────────────────────────────────────────── {%- endcomment -%}
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="na-header">
        {%- if section.settings.title != blank -%}
          <h2 class="na-header__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="na-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Tab pills ─────────────────────────────────────────── {%- endcomment -%}
    {%- if show_tabs -%}
      <div class="na-tabs" role="tablist">
        {%- for tab in tab_blocks -%}
          <button
            class="na-tab{% if forloop.first %} na-tab--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-panel="na-panel-{{ section.id }}-{{ tab.id }}"
          >{{ tab.settings.label }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Panels ────────────────────────────────────────────── {%- endcomment -%}
    {%- for tab in tab_blocks -%}
      {%- assign tab_collection = tab.settings.collection -%}
      {%- assign products_limit = tab.settings.products_limit | default: 8 -%}
      <div
        class="na-panel{% if forloop.first %} na-panel--active{% endif %}"
        id="na-panel-{{ section.id }}-{{ tab.id }}"
        role="tabpanel"
        {{ tab.shopify_attributes }}
      >
        <div class="na-grid">
          {%- if tab_collection != blank -%}
            {%- for product in tab_collection.products limit: products_limit -%}
              {%- render 'custom_product_card',
                product: product,
                section_id: section.id,
                cuotas_text: section.settings.cuotas_text,
                max_swatches: max_swatches
              -%}
            {%- endfor -%}

          {%- else -%}
            {%- comment -%} Placeholder cuando no hay colección asignada {%- endcomment -%}
            {%- for i in (1..6) -%}
              <div class="cg-card cg-card--placeholder">
                <div class="cg-card__media">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'cg-card__img' }}
                </div>
                <div class="cg-card__info">
                  {%- if section.settings.cuotas_text != blank -%}
                    <p class="cg-card__cuotas">{{ section.settings.cuotas_text }}</p>
                  {%- endif -%}
                  <span class="cg-card__title">Nombre del producto</span>
                  <div class="cg-card__bottom">
                    <div class="cg-card__price">
                      <span class="cg-card__price-current">$000.000</span>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

  </div>
</div>

{% stylesheet %}
  .custom-new-arrivals {
    box-sizing: border-box;
  }

  .na-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Header ── */
  .na-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .na-header__title {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: inherit;
  }

  .na-header__subtitle {
    margin: 0;
    font-size: 0.9rem;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  /* ── Tabs ── */
  .na-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .na-tab {
    padding: 8px 20px;
    border: 1.5px solid var(--na-tab-color);
    border-radius: 999px;
    background: transparent;
    color: var(--na-tab-color);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    line-height: 1;
  }

  .na-tab--active {
    background: var(--na-tab-active-bg);
    color: var(--na-tab-active-text);
    border-color: var(--na-tab-active-bg);
  }

  /* ── Panel ── */
  .na-panel {
    display: none;
  }

  .na-panel--active {
    display: block;
  }

  /* ── Grid ── */
  .na-grid {
    display: grid;
    grid-template-columns: repeat(var(--na-cols-mobile), 1fr);
    gap: 12px;
  }

  @media screen and (min-width: 750px) {
    .na-grid {
      gap: 16px;
      grid-template-columns: repeat(var(--na-cols-desktop), 1fr);
    }
  }
{% endstylesheet %}

<script>
(function () {
  var section = document.getElementById('new-arrivals-{{ section.id }}');
  if (!section) return;

  section.querySelectorAll('.na-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var panelId = btn.dataset.panel;
      section.querySelectorAll('.na-tab').forEach(function (b) {
        b.classList.toggle('na-tab--active', b === btn);
        b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
      });
      section.querySelectorAll('.na-panel').forEach(function (p) {
        p.classList.toggle('na-panel--active', p.id === panelId);
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Moxie New Arrivals",
  "tag": "section",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "tab",
      "name": "Pestaña de colección",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta de la pestaña",
          "default": "Hombre"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección"
        },
        {
          "type": "range",
          "id": "products_limit",
          "label": "Productos a mostrar",
          "min": 4,
          "max": 16,
          "step": 4,
          "default": 8
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo"
    },
    {
      "type": "header",
      "content": "Cuotas"
    },
    {
      "type": "text",
      "id": "cuotas_text",
      "label": "Texto de cuotas",
      "default": "0% de interés hasta 3 cuotas ver bancos"
    },
    {
      "type": "header",
      "content": "Pestañas"
    },
    {
      "type": "color",
      "id": "tab_color",
      "label": "Color del texto y borde",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Fondo pestaña activa",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_active_text",
      "label": "Texto pestaña activa",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Proporción de imagen",
      "options": [
        { "value": "2/3",  "label": "Retrato alto (2:3)" },
        { "value": "3/4",  "label": "Retrato (3:4)" },
        { "value": "1/1",  "label": "Cuadrado (1:1)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "label": "Columnas en desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cols_mobile",
      "label": "Columnas en mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo"
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Relleno vertical",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Moxie New Arrivals",
      "category": "Moxie",
      "settings": {
        "title": "New Arrivals",
        "cols_desktop": 4,
        "cols_mobile": 2,
        "image_ratio": "3/4",
        "cuotas_text": "0% de interés hasta 3 cuotas ver bancos"
      },
      "blocks": [
        { "type": "tab", "settings": { "label": "Hombre", "products_limit": 8 } },
        { "type": "tab", "settings": { "label": "Mujer",  "products_limit": 8 } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
