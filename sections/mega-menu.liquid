{%- comment -%}
  MOXIE: Megamenu — powered by Metaobjects.

  Metaobjetos requeridos:
    - megamenu_mic_category              (campos: titulo, enlace, banner_principal, banner_principal_link, banner_secundario, banner_secundario_link)
    - megamenu_little_mic_category       (mismos campos)
    - licencias_megamenu_mic_item_personajes       (campos: titulo, icono, enlace, banner, banner_link, subcategorias)
    - licencias_megamenu_little_mic_item_personajes (mismos campos)
{%- endcomment -%}

{%- liquid
  assign menu_mic  = section.settings.menu_mic
  assign menu_lm   = section.settings.menu_little_mic
  assign pers_trig = section.settings.personajes_trigger | handleize

  comment
    Cargar todos los metaobjetos de ambas marcas de una vez.
    Se renderizan en el HTML para ambas marcas y el JS/CSS controla la visibilidad.
  endcomment

  assign cats_mic = shop.metaobjects['megamenu_mic_category'].values
  assign cats_lm  = shop.metaobjects['megamenu_little_mic_category'].values
  assign lics_mic = shop.metaobjects['licencias_megamenu_mic_item_personajes'].values
  assign lics_lm  = shop.metaobjects['licencias_megamenu_little_mic_item_personajes'].values
-%}


<div
  id="moxie-megamenu"
  class="moxie-mega color-{{ section.settings.color_scheme }}"
  aria-hidden="true"
  style="--mega-border-radius: {{ section.settings.border_radius }}px;"
>
  <div class="moxie-mega__backdrop"></div>

  {%- comment -%} ══════════════ PANELES MIC ══════════════ {%- endcomment -%}
  <div class="moxie-mega__brand-wrap" data-brand-panels="mic">
    {%- for link in menu_mic.links -%}
      {%- if link.links.size > 0 -%}
        {%- assign link_key = link.title | handleize -%}
        {%- if link_key == pers_trig -%}
          {%- render 'mega-menu-personajes',
            link:      link,
            brand:     'mic',
            licencias: lics_mic
          -%}
        {%- else -%}
          {%- render 'mega-menu-standard',
            link:       link,
            brand:      'mic',
            categorias: cats_mic
          -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ══════════════ PANELES LITTLE MIC ══════════════ {%- endcomment -%}
  {%- if menu_lm != blank and menu_lm.links.size > 0 -%}
    <div class="moxie-mega__brand-wrap" data-brand-panels="little-mic">
      {%- for link in menu_lm.links -%}
        {%- if link.links.size > 0 -%}
          {%- assign link_key = link.title | handleize -%}
          {%- if link_key == pers_trig -%}
            {%- render 'mega-menu-personajes',
              link:      link,
              brand:     'little-mic',
              licencias: lics_lm
            -%}
          {%- else -%}
            {%- render 'mega-menu-standard',
              link:       link,
              brand:      'little-mic',
              categorias: cats_lm
            -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Moxie Megamenu",
  "settings": [
    {
      "type": "header",
      "content": "Menús de navegación"
    },
    {
      "type": "paragraph",
      "content": "Selecciona los menús creados en Online Store → Navigation. El menú debe tener 2 niveles: ítems del navbar → categorías (con sub-ítems opcionales como 3er nivel)."
    },
    {
      "type": "link_list",
      "id": "menu_mic",
      "label": "Menú MIC",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "menu_little_mic",
      "label": "Menú Little MIC",
      "info": "Si se deja vacío, Little MIC no tendrá megamenu."
    },
    {
      "type": "header",
      "content": "Panel especial Personajes"
    },
    {
      "type": "text",
      "id": "personajes_trigger",
      "label": "Nombre del ítem Personajes",
      "default": "Personajes",
      "info": "Texto exacto del ítem del navbar que debe abrir el panel de licencias. Se compara como handle (sin mayúsculas ni tildes)."
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color del panel",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio de borde inferior (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Moxie Megamenu",
      "category": "Moxie"
    }
  ]
}
{% endschema %}
