<script
  src="{{ 'custom-category-grid.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign s = section.settings
-%}

<div class="custom-center-container{% unless s.show_on_desktop %} mox-hidden-desktop{% endunless %}{% unless s.show_on_mobile %} mox-hidden-mobile{% endunless %}">
<div
  class="mox-cg color-{{ s.color_scheme }} custom-standar-max-width{% if s.padding_lateral_desktop %} custom-padding-left-right-only-desktop{% endif %}{% if s.padding_lateral_mobile %} custom-padding-left-right-only-tablet-mobile{% endif %}"
  style="
    --mox-cg-pt: {{ s.padding_top }}px;
    --mox-cg-pb: {{ s.padding_bottom }}px;
    --mox-cg-gap: {{ s.card_gap }}px;
    --mox-cg-visible: {{ s.slides_desktop }};
    --mox-cg-visible-mobile: {{ s.slides_mobile }};
    --mox-cg-label-size: {{ s.label_size }}px;
    --mox-cg-title-size: {{ s.title_size }}px;
    --mox-cg-header-gap: {{ s.header_gap }}px;
    {% unless s.bg_color == blank %}background-color: {{ s.bg_color }};{% endunless %}
  "
  {{ section.shopify_attributes }}
>

  {%- if s.title != blank or s.subtitle != blank -%}
    <div class="mox-cg__header">
      {%- if s.title != blank -%}
        <h2 class="mox-cg__title">{{ s.title }}</h2>
      {%- endif -%}
      {%- if s.subtitle != blank -%}
        <p class="mox-cg__subtitle">{{ s.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <category-grid-slider>

    {%- if s.show_arrows -%}
      <button class="mox-cg__arrow mox-cg__arrow--prev{% unless s.show_arrows_desktop %} mox-hidden-desktop{% endunless %}{% unless s.show_arrows_mobile %} mox-hidden-mobile{% endunless %}" ref="prev" aria-label="{{ 'moxie.slideshow.previous' | t }}" disabled>
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
    {%- endif -%}

    <div class="mox-cg__track">
      {%- for block in section.blocks -%}
        {%- liquid
          assign b = block.settings
          assign has_genders = false
          if b.show_gender_links and b.link_male != blank
            assign has_genders = true
          endif
          if b.show_gender_links and b.link_female != blank
            assign has_genders = true
          endif
        -%}

        <div class="mox-cg__card{% if has_genders and b.btn_hover_only %} mox-cg__card--btn-hover{% endif %}" {{ block.shopify_attributes }}>

          {%- if b.image != blank -%}
            {{
              b.image
              | image_url: width: 700
              | image_tag:
                class: 'mox-cg__img',
                loading: 'lazy',
                widths: '300, 400, 500, 600, 700',
                alt: b.label
            }}
          {%- else -%}
            {{ 'collection-apparel-1' | placeholder_svg_tag: 'mox-cg__img' }}
          {%- endif -%}

          <div class="mox-cg__overlay">
            {%- if b.sublabel != blank -%}
              <span class="mox-cg__sublabel">{{ b.sublabel }}</span>
            {%- endif -%}
            {%- if b.label != blank -%}
              <span class="mox-cg__label">{{ b.label }}</span>
            {%- endif -%}

            {%- if has_genders -%}
              <div class="mox-cg__genders">
                {%- if b.link_male != blank -%}
                  <a
                    class="mox-cg__gender-btn"
                    href="{{ b.link_male }}"
                    style="{% unless b.btn1_bg == blank %}--btn-bg:{{ b.btn1_bg }};{% endunless %}{% unless b.btn1_text == blank %}--btn-color:{{ b.btn1_text }};{% endunless %}{% unless b.btn1_hover == blank %}--btn-hover-bg:{{ b.btn1_hover }};{% endunless %}"
                  >{%- assign _male_fallback = 'moxie.nav.gender_male' | t -%}{{ b.label_male | default: _male_fallback }}</a>
                {%- endif -%}
                {%- if b.link_female != blank -%}
                  <a
                    class="mox-cg__gender-btn"
                    href="{{ b.link_female }}"
                    style="{% unless b.btn2_bg == blank %}--btn-bg:{{ b.btn2_bg }};{% endunless %}{% unless b.btn2_text == blank %}--btn-color:{{ b.btn2_text }};{% endunless %}{% unless b.btn2_hover == blank %}--btn-hover-bg:{{ b.btn2_hover }};{% endunless %}"
                  >{%- assign _female_fallback = 'moxie.nav.gender_female' | t -%}{{ b.label_female | default: _female_fallback }}</a>
                {%- endif -%}
              </div>
            {%- elsif b.link != blank -%}
              <a class="mox-cg__card-link" href="{{ b.link }}" aria-label="{{ b.label }}"></a>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

    {%- if s.show_arrows -%}
      <button class="mox-cg__arrow mox-cg__arrow--next{% unless s.show_arrows_desktop %} mox-hidden-desktop{% endunless %}{% unless s.show_arrows_mobile %} mox-hidden-mobile{% endunless %}" ref="next" aria-label="{{ 'moxie.slideshow.next' | t }}">
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}

    {%- if s.show_dots -%}
      {%- comment -%}
        MOXIE: dots are generated entirely by custom-category-grid.js.
        The number of reachable scroll positions depends on how many cards
        fit per view (slides_desktop/mobile), which can only be measured at
        runtime — one dot per block would be wrong whenever more than one
        card is visible at a time (see _pageCount in the JS file).
      {%- endcomment -%}
      <div class="mox-cg__dots{% unless s.show_dots_desktop %} mox-hidden-desktop{% endunless %}{% unless s.show_dots_mobile %} mox-hidden-mobile{% endunless %}" ref="dotsContainer"></div>
    {%- endif -%}

  </category-grid-slider>

</div>
</div>

{% schema %}
{
  "name": "Moxie Category Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Compra por categoría"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo / descripción"
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Espacio entre encabezado y slider",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "select",
      "id": "slides_desktop",
      "label": "Slides visibles — desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "2.5", "label": "2 + medio (2.5)" },
        { "value": "3", "label": "3" },
        { "value": "3.5", "label": "3 + medio (3.5)" },
        { "value": "4", "label": "4" },
        { "value": "4.5", "label": "4 + medio (4.5)" },
        { "value": "5", "label": "5" },
        { "value": "5.5", "label": "5 + medio (5.5)" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "slides_mobile",
      "label": "Slides visibles — móvil",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "1.3", "label": "1 + pico (1.3)" },
        { "value": "1.5", "label": "1 + medio (1.5)" },
        { "value": "2", "label": "2" },
        { "value": "2.5", "label": "2 + medio (2.5)" },
        { "value": "3", "label": "3" }
      ],
      "default": "1.5"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Mostrar flechas de navegación",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows_desktop",
      "label": "Flechas — mostrar en desktop",
      "default": true,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows_mobile",
      "label": "Flechas — mostrar en móvil",
      "default": true,
      "visible_if": "{{ section.settings.show_arrows }}"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Mostrar dots de navegación",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots_desktop",
      "label": "Dots — mostrar en desktop",
      "default": true,
      "visible_if": "{{ section.settings.show_dots }}"
    },
    {
      "type": "checkbox",
      "id": "show_dots_mobile",
      "label": "Dots — mostrar en móvil",
      "default": true,
      "visible_if": "{{ section.settings.show_dots }}"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Espacio entre slides",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Tamaño etiqueta de categoría",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo (sobreescribe el scheme)"
    },
    {
      "type": "header",
      "content": "Visibilidad"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Mostrar en desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Mostrar en móvil",
      "default": true
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_desktop",
      "label": "Padding lateral — desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_mobile",
      "label": "Padding lateral — mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Nombre de categoría",
          "default": "Jeans"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Texto secundario (pequeño)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (cuando no hay botones)"
        },
        {
          "type": "header",
          "content": "Botones"
        },
        {
          "type": "checkbox",
          "id": "show_gender_links",
          "label": "Mostrar botones",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "btn_hover_only",
          "label": "Botones solo al hover en desktop (si no, siempre visibles)",
          "default": true,
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        
        {
          "type": "text",
          "id": "label_male",
          "label": "Boton 1 — Etiqueta",
          "default": "Hombre",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "url",
          "id": "link_male",
          "label": "Boton 1 — Enlace",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "color",
          "id": "btn1_bg",
          "label": "Boton 1 — Color fondo",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "color",
          "id": "btn1_text",
          "label": "Boton 1 — Color texto",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "color",
          "id": "btn1_hover",
          "label": "Boton 1 — Color fondo hover",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "text",
          "id": "label_female",
          "label": "Boton 2 — Etiqueta",
          "default": "Mujer",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "url",
          "id": "link_female",
          "label": "Boton 2 — Enlace",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "color",
          "id": "btn2_bg",
          "label": "Boton 2 — Color fondo",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "color",
          "id": "btn2_text",
          "label": "Boton 2 — Color texto",
          "visible_if": "{{ block.settings.show_gender_links }}"
        },
        {
          "type": "color",
          "id": "btn2_hover",
          "label": "Boton 2 — Color fondo hover",
          "visible_if": "{{ block.settings.show_gender_links }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Moxie Category Grid",
      "category": "Moxie",
      "blocks": [
        { "type": "category", "settings": { "label": "Jeans", "show_gender_links": true } },
        { "type": "category", "settings": { "label": "Buzos" } },
        { "type": "category", "settings": { "label": "Chaquetas" } },
        { "type": "category", "settings": { "label": "Camisetas" } },
        { "type": "category", "settings": { "label": "Accesorios" } }
      ]
    }
  ]
}
{% endschema %}
