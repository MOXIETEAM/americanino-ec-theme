<script
  src="{{ 'custom-category-grid.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign s = section.settings
-%}

<div class="custom-center-container">
<div
  class="mox-cg color-{{ s.color_scheme }} custom-standar-max-width"
  style="
    --mox-cg-pt: {{ s.padding_top }}px;
    --mox-cg-pb: {{ s.padding_bottom }}px;
    --mox-cg-gap: {{ s.card_gap }}px;
    --mox-cg-visible: {{ s.slides_desktop }};
    --mox-cg-visible-mobile: {{ s.slides_mobile }};
    --mox-cg-label-size: {{ s.label_size }}px;
    --mox-cg-title-size: {{ s.title_size }}px;
    --mox-cg-header-gap: {{ s.header_gap }}px;
    {% unless s.bg_color == blank %}background-color: {{ s.bg_color }};{% endunless %}
  "
  {{ section.shopify_attributes }}
>

  {%- if s.title != blank or s.subtitle != blank -%}
    <div class="mox-cg__header">
      {%- if s.title != blank -%}
        <h2 class="mox-cg__title">{{ s.title }}</h2>
      {%- endif -%}
      {%- if s.subtitle != blank -%}
        <p class="mox-cg__subtitle">{{ s.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <category-grid-slider>

    {%- if s.show_arrows -%}
      <button class="mox-cg__arrow mox-cg__arrow--prev" ref="prev" aria-label="Anterior" disabled>
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
    {%- endif -%}

    <div class="mox-cg__track">
      {%- for block in section.blocks -%}
        {%- liquid
          assign b = block.settings
          assign has_genders = false
          if b.show_gender_links and b.link_male != blank
            assign has_genders = true
          endif
          if b.show_gender_links and b.link_female != blank
            assign has_genders = true
          endif
        -%}

        <div class="mox-cg__card" {{ block.shopify_attributes }}>

          {%- if b.image != blank -%}
            {{
              b.image
              | image_url: width: 700
              | image_tag:
                class: 'mox-cg__img',
                loading: 'lazy',
                widths: '300, 400, 500, 600, 700',
                alt: b.label
            }}
          {%- else -%}
            {{ 'collection-apparel-1' | placeholder_svg_tag: 'mox-cg__img' }}
          {%- endif -%}

          <div class="mox-cg__overlay">
            {%- if b.label != blank -%}
              <span class="mox-cg__label">{{ b.label }}</span>
            {%- endif -%}

            {%- if has_genders -%}
              <div class="mox-cg__genders">
                {%- if b.link_male != blank -%}
                  <a class="mox-cg__gender-btn" href="{{ b.link_male }}">
                    {{ b.label_male | default: 'Hombre' }}
                  </a>
                {%- endif -%}
                {%- if b.link_female != blank -%}
                  <a class="mox-cg__gender-btn" href="{{ b.link_female }}">
                    {{ b.label_female | default: 'Mujer' }}
                  </a>
                {%- endif -%}
              </div>
            {%- elsif b.link != blank -%}
              <a class="mox-cg__card-link" href="{{ b.link }}" aria-label="{{ b.label }}"></a>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

    {%- if s.show_arrows -%}
      <button class="mox-cg__arrow mox-cg__arrow--next" ref="next" aria-label="Siguiente">
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    {%- endif -%}

    {%- if s.show_dots -%}
      <div class="mox-cg__dots" ref="dotsContainer">
        {%- for block in section.blocks -%}
          <button
            class="mox-cg__dot{% if forloop.first %} mox-cg__dot--active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Slide {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </category-grid-slider>

</div>
</div>

{% schema %}
{
  "name": "Moxie Category Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Compra por categoría"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo / descripción"
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Espacio entre encabezado y slider",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "select",
      "id": "slides_desktop",
      "label": "Slides visibles — desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "2.5", "label": "2 + medio (2.5)" },
        { "value": "3", "label": "3" },
        { "value": "3.5", "label": "3 + medio (3.5)" },
        { "value": "4", "label": "4" },
        { "value": "4.5", "label": "4 + medio (4.5)" },
        { "value": "5", "label": "5" },
        { "value": "5.5", "label": "5 + medio (5.5)" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "slides_mobile",
      "label": "Slides visibles — móvil",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "1.3", "label": "1 + pico (1.3)" },
        { "value": "1.5", "label": "1 + medio (1.5)" },
        { "value": "2", "label": "2" },
        { "value": "2.5", "label": "2 + medio (2.5)" },
        { "value": "3", "label": "3" }
      ],
      "default": "1.5"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Mostrar flechas de navegación",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Mostrar dots de navegación",
      "default": false
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Espacio entre slides",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Tamaño etiqueta de categoría",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo (sobreescribe el scheme)"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Nombre de categoría",
          "default": "Jeans"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (cuando no hay botones)"
        },
        {
          "type": "header",
          "content": "Botones"
        },
        {
          "type": "checkbox",
          "id": "show_gender_links",
          "label": "Mostrar botones",
          "default": false
        },
        {
          "type": "text",
          "id": "label_male",
          "label": "Etiqueta Boton 1",
          "default": "Hombre"
        },
        {
          "type": "url",
          "id": "link_male",
          "label": "Enlace Boton 1"
        },
        {
          "type": "text",
          "id": "label_female",
          "label": "Etiqueta Boton 2",
          "default": "Mujer"
        },
        {
          "type": "url",
          "id": "link_female",
          "label": "Enlace Boton 2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Moxie Category Grid",
      "category": "Moxie",
      "blocks": [
        { "type": "category", "settings": { "label": "Jeans", "show_gender_links": true } },
        { "type": "category", "settings": { "label": "Buzos" } },
        { "type": "category", "settings": { "label": "Chaquetas" } },
        { "type": "category", "settings": { "label": "Camisetas" } },
        { "type": "category", "settings": { "label": "Accesorios" } }
      ]
    }
  ]
}
{% endschema %}
