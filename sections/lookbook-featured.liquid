{% style %}
.lookbook {
  padding: {{ section.settings.padding_top | default: 60 }}px 20px {{ section.settings.padding_bottom | default: 60 }}px;
}

.lookbook-header {
  margin-bottom: {{ section.settings.header_gap | default: 32 }}px;
}

.lookbook-mox-header-title {
  h1, h2, h3, h4, h5, h6, p {
  font-weight: 500;
  font-size: {{ section.settings.title_size | default: 32 }}px;
  line-height: 100%;
  color: #1E2B51;
  text-transform: none;
  }
}

.lookbook-mox-header-subtitle {
  h1, h2, h3, h4, h5, h6, p {
    font-weight: 300;
    font-size: 15px;
    line-height: 18px;
    color: #1E2B51;
    text-transform: none;
  }
}

.lookbook-grid {
  display: grid;
  grid-template-columns: 150px 1fr 380px;
  gap: 48px;
  align-items: start;
  padding: 0 6%;
}

/* THUMBS */
.lb-thumbs {
  display: flex;
  flex-direction: column;
  gap: {{ section.settings.slides_gap | default: 8 }}px;
  margin-top: 90px;
}

.lb-thumb {
  width: 100%;
  aspect-ratio: 146 / 181;
  object-fit: cover;
  cursor: pointer;
  border-radius: 5px;
  display: block;
}

.lb-thumb.active {
  opacity: 1;
  outline: 2px solid #1E2B51;
  outline-offset: 2px;
}

/* MAIN */
.lb-main {
  position: relative;
}

.lb-main-img {
  width: 100%;
  border-radius: 4px;
  display: block;
  {% unless section.settings.banner_ratio == 'auto' %}
  aspect-ratio: {{ section.settings.banner_ratio }};
  object-fit: cover;
  height: auto;
  {% endunless %}
}

/* HOTSPOT */
.lb-hotspot {
  position: absolute;
  width: 29px;
  height: 29px;
  background-image: url('https://cdn.shopify.com/s/files/1/0980/2380/1123/files/a9d9692f7e9ecdda3e745c1184e08629e5ec3667_1.gif?v=1784486135');
  background-size: cover;
  background-position: center;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,.2);
  transform: translate(-50%, -50%);
  transition: box-shadow .2s;
  z-index: 2;
}

.lb-hotspot.active {
  /* box-shadow: 0 0 0 2px #1E2B51, 0 2px 8px rgba(0,0,0,.2); */
}

/* RIGHT PANEL */

.lb-info {
  padding: 20px 0;
}

.lb-info
.lb-info-small-product-card-mox {
   font-weight: 300;
    font-size: 16px;
    line-height: 18px;
    color: #1E2B51;
    text-transform: none;
    margin-bottom: 10px;
}


.lb-info
.lb-info-heading-product-card-mox {
  h1, h2, h3, h4, h5, h6, p {
font-weight: 500;
font-size: 33px;
line-height: 100%;
letter-spacing: 0%;
color: #1E2B51;
text-transform: none;
margin-bottom: 20px;
  }
}

/* PRODUCT CARD */
.lb-product {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.lb-product-img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 340 / 502;
  background: #f3f3f3;
}

.lb-product-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease, opacity 0.4s ease;
}

.lb-product-img-wrap .lb-product-img--second {
  position: absolute;
  inset: 0;
  opacity: 0;
}

.lb-product-img-wrap:hover .lb-product-img--first {
  transform: scale(1.03);
}

.lb-product-img-wrap:hover .lb-product-img--second {
  opacity: 1;
}

@media (prefers-reduced-motion: reduce) {
  .lb-product-img-wrap img {
    transition: none;
  }
}

.lb-installments {
font-weight: 400;
font-size: 11.5px;
line-height: 100%;
letter-spacing: 0%;
vertical-align: middle;

  color: #737373;
  margin: 0;
}

.lb-installments p {
  margin: 0;
}

.lb-title {
  font-size: 13px;
  font-weight: 500;
  color: #1E2B51;
  line-height: 18px;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  line-clamp: 1;
  overflow: hidden;
}

.lb-price {
  display: flex;
  align-items: baseline;
  gap: 8px;
font-weight: 600;
font-size: 14px;
line-height: 100%;
letter-spacing: 0%;
vertical-align: middle;
text-transform: capitalize;

  color: #24272A;
}

.lb-price del {
  color: #aaa;
  font-size: 0.8125rem;
  font-style: normal;
}

.lb-price span {
  font-weight: 700;
  color: #1a1a2e;
}

.lb-swatches {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  align-items: center;
}

.lb-swatch {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 1.5px solid rgba(0,0,0,.15);
  display: inline-block;
  flex-shrink: 0;
}

/* MOBILE */
/* MOXIE: breakpoint mobile↔desktop en 990px (no 900px) */
@media(max-width: 990px){
  .lookbook-grid {
    grid-template-columns: 1fr;
    padding: 0 !important;
  }

  .lb-thumbs {
    flex-direction: row;
    overflow-x: auto;
  }

  .lb-thumb {
    min-width: 90px;
    max-width: 92px;
    aspect-ratio: 92 / 114;
    flex-shrink: 0;
  }

    .lookbook {
    padding: 30px 20px;
  }

  .lookbook-header {
    margin-bottom: 10px;
  }

  .lookbook-grid {
    gap: 20px;
  }

  .lb-thumbs {
    margin-top: 0;
  }

  .lb-info {
    display: none;
  }
}

/* ── Mobile quick-add drawer ──────────────────────────────── */

.lb-mobile-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 399;
  background: rgba(0, 0, 0, 0.5);
}
.lb-mobile-overlay--visible {
  display: block;
  animation: lb-overlay-in 0.22s ease both;
}
@keyframes lb-overlay-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.lb-mobile-drawer {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 400;
  background: #fff;
  border-radius: 16px 16px 0 0;
  box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.15);
}
.lb-mobile-drawer__body {
  padding: 20px 20px 0px;
  max-height: 85vh;
  overflow-y: auto;
  overscroll-behavior: contain;
}
.lb-mobile-drawer--open {
  display: block;
  animation: lb-slide-up 0.3s cubic-bezier(0.33, 1, 0.68, 1) both;
}
@keyframes lb-slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.lb-mobile-drawer__close {
  position: absolute;
  top: -16px;
  right: 50%;
  transform: translateX(50%);
  width: 28px;
  height: 28px;
  padding: 0;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  transition: background 0.15s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb-mobile-drawer__close:hover {
  background: rgba(255, 255, 255, 0.85);
}
