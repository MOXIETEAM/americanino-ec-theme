.lb-mobile-drawer__close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 13px;
  height: 2px;
  background: #111;
  border-radius: 1px;
  pointer-events: none;
}
.lb-mobile-drawer__close::before {
  transform: translate(-50%, -50%) rotate(45deg);
}
.lb-mobile-drawer__close::after {
  transform: translate(-50%, -50%) rotate(-45deg);
} */

/* Product layout inside drawer */
.lb-md-product {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 14px;
  align-items: start;
}
.lb-md-img {
  width: 100px;
  height: 134px;
  object-fit: cover;
  display: block;
}
.lb-md-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.lb-swatches-add-to-cart-btn {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  /* flex-wrap: wrap; */
}
.lb-md-installments {
  margin: 0;
  font-weight: 400;
  font-size: 11px;
  line-height: 1.3;
  color: #737373;
}

.lb-md-installments p {
  margin: 0;
}
.lb-md-title {
  margin: 0;
  font-weight: 500;
  font-size: 13px;
  line-height: 1.3;
  color: #1E2B51;
}
.lb-md-price {
  display: flex;
  align-items: baseline;
  gap: 6px;
  flex-wrap: wrap;
}
.lb-md-compare {
  font-size: 12px;
  color: rgba(0, 0, 0, 0.45);
  font-style: normal;
  text-decoration: line-through;
}
.lb-md-current {
  font-weight: 600;
  font-size: 14px;
  color: #2C2C2C;
}

.lb-md-variant-selector {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.lb-md-option-label {
  font-weight: 500;
  font-size: 13px;
  color: #1E2B51;
  margin-top: 4px;
}
.lb-md-select {
  min-width: 90px;
  max-width: 94px;
  min-height: 27px;
  padding: 0 10px;
  border: 1px solid #1E2B51;
  border-radius: 23px;
  font-weight: 500;
  font-size: 14px;
  color: #1E2B51;
  background: transparent;
  cursor: pointer;
  appearance: auto;
}
.lb-md-add-btn {
  width: 100%;
  max-width: 147px;
  max-height: 27px;
  /* margin-top: 6px; */
  padding: 10px 16px;
  font-size: 11px;
  font-weight: 500;
  line-height: 1.4;
  border-radius: 27px;
  border: 1px solid #1E2B51;
  background: #1E2B51;
  color: #fff;
  cursor: pointer;
  text-align: center;
  transition: background 0.18s ease, opacity 0.18s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb-md-add-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}


