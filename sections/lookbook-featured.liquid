    padding: 30px 20px;
  }

  .lookbook-header {
    margin-bottom: 10px;
  }

  .lookbook-grid {
    gap: 20px;
  }

  .lb-thumbs {
    margin-top: 0;
  }

  .lb-info {
    display: none;
  }
} */

{% endstyle %}

{%- liquid
  assign s = section.settings
  assign inst = s.installments_text
-%}

<div class="custom-center-container{% unless s.show_on_desktop %} mox-hidden-desktop{% endunless %}{% unless s.show_on_mobile %} mox-hidden-mobile{% endunless %}">
<div class="lookbook custom-standar-max-width" {{ section.shopify_attributes }}>

  <!-- HEADER -->
  <div class="lookbook-header">
    <div class="lookbook-mox-header-title">
      {%- if s.title != blank -%}<h2>{{ s.title }}</h2>{%- endif -%}
    </div>
    <div class="lookbook-mox-header-subtitle">
      {%- if s.subtitle != blank -%}<p>{{ s.subtitle }}</p>{%- endif -%}
    </div>
  </div>

  <div class="lookbook-grid">

    <!-- THUMBNAILS -->
    <div class="lb-thumbs">
      {%- for block in section.blocks -%}
        {%- if block.type == 'look' -%}
          <img
            class="lb-thumb{% if forloop.first %} active{% endif %}"
            src="{{ block.settings.image | image_url: width: 200 }}"
            data-look="{{ block.settings.look_id }}"
            alt="{{ block.settings.look_id }}"
            {{ block.shopify_attributes }}
            width="auto"
            height="auto"
          >
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- MAIN IMAGE -->
    {%- assign first_look = section.blocks | where: "type", "look" | first -%}
    <div class="lb-main" id="lb-main">
      {%- if first_look -%}
        <img
          id="lb-main-img"
          class="lb-main-img"
          src="{{ first_look.settings.image | image_url: width: 900 }}"
          data-look="{{ first_look.settings.look_id }}"
          alt=""
          width="auto"
          height="auto"
        >
      {%- endif -%}
    </div>

    <!-- RIGHT INFO -->
    <div class="lb-info">
      <div class="lb-info-small-product-card-mox">
        {%- if s.small != blank -%}<p>{{ s.small }}</p>{%- endif -%}
      </div>
      <div class="lb-info-heading-product-card-mox">
        {%- if s.heading != blank -%}<h3>{{ s.heading }}</h3>{%- endif -%}
      </div>
      <div id="lb-product-box"></div>
    </div>

  </div>
</div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const mainImg    = document.getElementById("lb-main-img");
  const mainWrap   = document.getElementById("lb-main");
  const productBox = document.getElementById("lb-product-box");

  if (!mainImg) return;

  // ── Look images ───────────────────────────────────────────────────────────
  const looks = {
    {% for block in section.blocks %}
      {% if block.type == 'look' %}
      "{{ block.settings.look_id }}": "{{ block.settings.image | image_url: width: 900 }}",
      {% endif %}
    {% endfor %}
  };

  // ── Pin data ──────────────────────────────────────────────────────────────
  const allPins = [
    {% for block in section.blocks %}
      {% if block.type == 'pin' %}
        {%- assign pin_prod = all_products[block.settings.product] -%}
        {%- liquid
          assign pin_has_disc = false
          if pin_prod.compare_at_price > pin_prod.price
            assign pin_has_disc = true
          endif

          assign pin_color_idx = nil
          for opt in pin_prod.options
            assign opt_lower = opt | downcase
            if opt_lower == 'color' or opt_lower == 'colour'
              assign pin_color_idx = forloop.index0
              break
            endif
          endfor

          assign pin_colors = ''
          if pin_color_idx != nil
            for variant in pin_prod.variants
              assign cval = variant.options[pin_color_idx]
              unless pin_colors contains cval
                assign pin_colors = pin_colors | append: cval | append: '||'
              endunless
            endfor
          endif
          assign pin_color_list = pin_colors | split: '||'

          assign pin_selected = pin_prod.selected_or_first_available_variant

          # MOXIE: segunda imagen para el efecto hover — primer media distinto al featured
          assign pin_second_media = nil
          for media in pin_prod.media
            unless media == pin_prod.featured_media
              assign pin_second_media = media
              break
            endunless
          endfor
        -%}
    {
      look: "{{ block.settings.look_id }}",
      top:  {{ block.settings.top }},
      left: {{ block.settings.left }},
      isDefault: {{ block.settings.is_default }},
      html: `<div class="lb-product">
        <div class="lb-product-img-wrap">
          <a href="{{ pin_prod.url }}">
            <img class="lb-product-img--first" src="{{ pin_prod.featured_image | image_url: width: 500 }}" alt="{{ pin_prod.title | escape }}">
            {% if pin_second_media %}<img class="lb-product-img--second" src="{{ pin_second_media.preview_image | image_url: width: 500 }}" alt="">{% endif %}
          </a>
        </div>
        {% if inst != blank %}<div class="lb-installments">{{ inst }}</div>{% endif %}
        <p class="lb-title">{{ pin_prod.title | escape }}</p>
        <div class="lb-price">
          {% if pin_has_disc %}<del>{{ pin_prod.compare_at_price | money }}</del>{% endif %}
          <span>{{ pin_prod.price | money }}</span>
        </div>
        {% if pin_color_list.size > 0 %}
        <div class="lb-swatches">
          {% for cval in pin_color_list %}{% if cval != blank %}<span class="lb-swatch" title="{{ cval | escape }}" style="background-color:{{ cval | downcase | replace: ' ', '' }};"></span>{% endif %}{% endfor %}
        </div>
        {% endif %}
      </div>`,
      mobileHtml: `<div class="lb-md-product">
        <img class="lb-md-img" src="{{ pin_prod.featured_image | image_url: width: 200 }}" alt="{{ pin_prod.title | escape }}" width="100" height="134" loading="lazy">
        <div class="lb-md-info">
          {% if inst != blank %}<div class="lb-md-installments">{{ inst }}</div>{% endif %}
          <p class="lb-md-title">{{ pin_prod.title | escape }}</p>
          <div class="lb-md-price">
            {% if pin_has_disc %}<s class="lb-md-compare">{{ pin_prod.compare_at_price | money }}</s>{% endif %}
            <span class="lb-md-current">{{ pin_prod.price | money }}</span>
          </div>
          <div class="lb-swatches-add-to-cart-btn">
            {% for cval in pin_color_list %}{% if cval != blank %}<span class="lb-swatch" title="{{ cval | escape }}" style="background-color:{{ cval | downcase | replace: ' ', '' }};"></span>{% endif %}{% endfor %}
          {% if pin_prod.variants.size > 1 %}
           <div class="lb-md-variant-selector">
            <label class="lb-md-option-label" for="lb-sel-{{ pin_prod.id }}-{{ block.id }}">{{ pin_prod.options.first | escape }}</label>
            <select id="lb-sel-{{ pin_prod.id }}-{{ block.id }}" class="lb-md-select">
              {% for variant in pin_prod.variants %}<option value="{{ variant.id }}"{% unless variant.available %} disabled{% endunless %}{% if variant == pin_selected %} selected{% endif %}>{{ variant.title | escape }}</option>{% endfor %}
            </select>
           </div>
          {% endif %}
          <button class="lb-md-add-btn" data-variant-id="{{ pin_selected.id }}"{% unless pin_selected.available %} disabled{% endunless %}>
            {% if pin_selected.available %}Añadir a la bolsa{% else %}Agotado{% endif %}
          </button>
          
          </div>
        </div>
      </div>`
    },
      {% endif %}
    {% endfor %}
  ];

  // ── Mobile bottom sheet ───────────────────────────────────────────────────

  const overlay = document.createElement('div');
  overlay.className = 'lb-mobile-overlay';
  document.body.appendChild(overlay);

  const drawer = document.createElement('div');
  drawer.className = 'lb-mobile-drawer';
  document.body.appendChild(drawer);

  // MOXIE: bloquea el scroll del body mientras el drawer mobile está abierto
  let lockedScrollY = 0;

  function lockBodyScroll() {
    lockedScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${lockedScrollY}px`;
    document.body.style.width = '100%';
  }

  function unlockBodyScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.width = '';
    window.scrollTo({ top: lockedScrollY, behavior: 'instant' });
  }

  function closeDrawer() {
    const wasOpen = drawer.classList.contains('lb-mobile-drawer--open');
    overlay.classList.remove('lb-mobile-overlay--visible');
    drawer.classList.remove('lb-mobile-drawer--open');
    if (wasOpen) unlockBodyScroll();
  }

  overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });

  async function handleAddToCart(e) {
    const btn = /** @type {HTMLButtonElement} */ (e.currentTarget);
    const variantId = btn.dataset.variantId;
    if (!variantId) return;

    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = '…';

    try {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ id: Number(variantId), quantity: 1 })
      });
      if (!res.ok) throw new Error();

      const cart = await fetch('/cart.js').then((r) => r.json());

      // MOXIE: dispara el evento nativo del theme (ThemeEvents.cartUpdate, ver assets/events.js)
      // para que cart-drawer-component abra el minicart y el resto de componentes se sincronicen
      document.dispatchEvent(new CustomEvent('cart:update', {
        bubbles: true,
        detail: {
          resource: cart,
          sourceId: 'lookbook-featured',
          data: {
            source: 'lookbook-featured',
            itemCount: cart.item_count,
          },
        },
      }));

      closeDrawer();
      btn.textContent = originalText;
      btn.disabled = false;
    } catch {
      btn.textContent = originalText;
      btn.disabled = false;
    }
  }

  function openMobileDrawer(mobileHtml) {
    drawer.innerHTML = `
      <button class="lb-mobile-drawer__close" aria-label="Cerrar"> <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M0 11L4.29349 5.22741L0.399395 0H2.67927L5.52496 3.8965H5.59153L8.42058 0H10.5673L6.68986 5.21137L11 11H8.73676L5.49168 6.54227H5.39183L2.16339 11H0Z" fill="#2C2C2C"/>
</svg>
</button>
      <div class="lb-mobile-drawer__body">${mobileHtml}</div>
    `;

    drawer.querySelector('.lb-mobile-drawer__close')
      ?.addEventListener('click', closeDrawer);

    drawer.querySelector('.lb-md-select')
      ?.addEventListener('change', (e) => {
        const select = /** @type {HTMLSelectElement} */ (e.target);
        const btn = drawer.querySelector('.lb-md-add-btn');
        if (btn) btn.dataset.variantId = select.value;
      });

    drawer.querySelector('.lb-md-add-btn')
      ?.addEventListener('click', handleAddToCart);

    lockBodyScroll();

    void overlay.offsetWidth;
    overlay.classList.add('lb-mobile-overlay--visible');
    drawer.classList.add('lb-mobile-drawer--open');
  }

  // ── Render pins ───────────────────────────────────────────────────────────
  function renderPins(lookId) {
    mainWrap.querySelectorAll(".lb-hotspot").forEach(el => el.remove());

    const pins = allPins.filter(p => p.look === lookId);
    if (!pins.length) { productBox.innerHTML = ""; return; }

    const defaultPin = pins.find(p => p.isDefault) || pins[0];
    let defaultEl = null;

    pins.forEach(pin => {
      const el = document.createElement("div");
      el.className = "lb-hotspot";
      el.style.top  = pin.top  + "%";
      el.style.left = pin.left + "%";

      el.addEventListener("click", () => {
        mainWrap.querySelectorAll(".lb-hotspot").forEach(h => h.classList.remove("active"));
        el.classList.add("active");

        if (window.matchMedia('(max-width: 989px)').matches) {
          openMobileDrawer(pin.mobileHtml);
        } else {
          productBox.innerHTML = pin.html;
        }
      });

      mainWrap.appendChild(el);
      if (pin === defaultPin) defaultEl = el;
    });

    // Auto-activate default: show product card on desktop, not on mobile
    if (defaultEl) {
      defaultEl.classList.add("active");
      if (!window.matchMedia('(max-width: 989px)').matches) {
        productBox.innerHTML = defaultPin.html;
      }
    }
  }

  // ── Thumbnail click ───────────────────────────────────────────────────────
  document.querySelectorAll(".lb-thumb").forEach(thumb => {
    thumb.addEventListener("click", () => {
      document.querySelectorAll(".lb-thumb").forEach(t => t.classList.remove("active"));
      thumb.classList.add("active");

      const lookId = thumb.dataset.look;
      mainImg.src          = looks[lookId];
      mainImg.dataset.look = lookId;

      renderPins(lookId);
    });
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  renderPins(mainImg.dataset.look);

});
</script>
{%- content_for 'blocks' -%}

