
{%- liquid
  assign s = section.settings
  assign layout = s.layout | default: 'carousel'
  assign is_static = false
  if layout == 'static'
    assign is_static = true
  endif
  assign autoplay = false
  assign show_arrows = false
  if section.blocks.size > 1
    assign autoplay = true
    assign show_arrows = true
  endif
-%}

{%- comment -%} MOXIE: siempre carga el JS cuando hay múltiples items — en móvil
  el modo estático también necesita rotación automática. {%- endcomment -%}
{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

<div
  class="section-background color-{{ s.color_scheme }} custom-announcement-bar-moxie-container"
  {% unless s.bar_bg_color == blank %}style="background-color: {{ s.bar_bg_color }};"{% endunless %}
></div>

<aside
  class="custom-announcement-bar-moxie announcement-bar spacing-style section section--{{ s.section_width }} color-{{ s.color_scheme }}{% if is_static %} announcement-bar--static{% endif %}{% if s.padding_lateral_desktop %} custom-padding-left-right-only-desktop{% endif %}{% if s.padding_lateral_mobile %} custom-padding-left-right-only-tablet-mobile{% endif %}"
  style="
    {% render 'spacing-padding', settings: s %};
    --border-bottom-width: {{ s.divider_width }}px;
    font-weight: {{ s.font_weight }};
    font-style: {{ s.font_style }};
    {% unless s.bar_text_color == blank %}color: {{ s.bar_text_color }};{% endunless %}
    {% unless s.font_size == blank %}font-size: {{ s.font_size }};{% endunless %}
    {% unless s.letter_spacing == blank %}letter-spacing: {{ s.letter_spacing }};{% endunless %}
  "
>
  <announcement-bar-component
    class="announcement-bar__slider"
    {% if autoplay %}
      autoplay="{{ s.speed }}" aria-live="polite"
    {% endif %}
  >
    {% if show_arrows %}
      {%- liquid
        assign arrows_class = ''
        unless s.show_arrows_desktop
          assign arrows_class = arrows_class | append: ' mox-hidden-desktop'
        endunless
        unless s.show_arrows_mobile
          assign arrows_class = arrows_class | append: ' mox-hidden-mobile'
        endunless
        # MOXIE: layout "static" shows every message in a row on desktop (nothing
        # to navigate there), but always behaves as a single-slide carousel on
        # mobile (see stylesheet below) — so force-hide arrows on desktop only,
        # keeping them available on mobile per show_arrows_mobile.
        if is_static
          assign arrows_class = arrows_class | append: ' mox-hidden-desktop'
        endif
      -%}
      {% render 'slideshow-arrows', icon_style: 'chevron', class: arrows_class %}
    {% endif %}

    <div class="announcement-bar__slides">
      {% content_for 'blocks' %}
    </div>
  </announcement-bar-component>
</aside>

{% stylesheet %}
  .custom-announcement-bar-moxie {
    max-height: 37px;
    overflow: hidden;
  }

  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .announcement-bar__slider {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  /* ── Carousel mode (default) ─────────────────────────────────────────────── */
  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: calc(100% - var(--button-size) * 2);
    /* max-width: 680px; */
    margin-inline: auto;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;

    &[aria-hidden='true'] {
      opacity: 0;
      visibility: hidden;
    }
  }

  .announcement-bar__slider slideshow-arrows {
    padding: 0;
    mix-blend-mode: normal;
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--color-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    padding: 0;
    width: var(--button-size);
    height: var(--button-size);
    align-items: center;
    justify-content: center;
    opacity: 1;
    animation: none;

    @media screen and (min-width: 750px) {
      --slideshow-control-offset: calc((var(--button-size) - var(--icon-size-xs)) / 2);

      .section--page-width &.slideshow-control--previous {
        transform: translateX(var(--slideshow-control-offset));
      }
    }
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .announcement-bar__slide {
    place-content: center;
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  /* ── Static mode: todos los items visibles en fila ───────────────────────── */
  .announcement-bar--static .announcement-bar__slides {
    display: flex;
    align-items: stretch;
    width: 100%;
    max-width: none;
    margin-inline: 0;
  }

  .announcement-bar--static .announcement-bar__slides > * {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    grid-area: unset;
  }

  /* Anula el ocultar por aria-hidden — en modo estático no hay carrusel */
  .announcement-bar--static .announcement-bar__slide[aria-hidden='true'] {
    opacity: 1 !important;
    visibility: visible !important;
    transition: none;
  }

  /* ── MOXIE: En móvil, modo estático se comporta como carrusel ─────────────
     El JS ya corre y maneja aria-hidden. Solo se necesita:
     1. Layout de grid/stack (1 item visible a la vez)
     2. Eliminar el override de aria-hidden para que el JS controle visibilidad */
  @media screen and (max-width: 749px) {
    .announcement-bar--static .announcement-bar__slides {
      display: grid;
      grid: [stack] auto / [stack] auto;
      width: calc(100% - var(--button-size) * 2);
      max-width: unset;
      margin-inline: auto;
    }

    .announcement-bar--static .announcement-bar__slides > * {
      grid-area: stack;
      flex: unset;
    }

    .announcement-bar--static .announcement-bar__slide[aria-hidden='true'] {
      opacity: 0 !important;
      visibility: hidden !important;
      transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Moxie Header Bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Modo de visualización"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Tipo de layout",
      "options": [
        { "value": "carousel", "label": "Carrusel (rotar mensajes)" },
        { "value": "static", "label": "Estático (todos visibles en fila)" }
      ],
      "default": "static"
    },
    {
      "type": "checkbox",
      "id": "show_arrows_desktop",
      "label": "Flechas — mostrar en desktop",
      "default": true,
      "info": "Solo aplica en modo Carrusel — en Estático nunca se muestran en desktop, ya que todos los mensajes se ven en fila."
    },
    {
      "type": "checkbox",
      "id": "show_arrows_mobile",
      "label": "Flechas — mostrar en móvil",
      "default": true,
      "info": "En móvil siempre se comporta como carrusel (incluso en modo Estático), así que esta opción aplica en ambos modos."
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Seminegrita" },
        { "value": "700", "label": "Negrita" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Estilo",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Tamaño de fuente",
      "options": [
        { "value": "", "label": "Predeterminado" },
        { "value": "0.625rem", "label": "10px" },
        { "value": "0.75rem", "label": "12px" },
        { "value": "0.8125rem", "label": "13px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" }
      ],
      "default": "0.8125rem"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Espaciado entre letras",
      "options": [
        { "value": "", "label": "Predeterminado" },
        { "value": "0", "label": "Ninguno" },
        { "value": "0.04em", "label": "Poco" },
        { "value": "0.08em", "label": "Medio" },
        { "value": "0.12em", "label": "Mucho" }
      ],
      "default": "0.04em"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "bar_bg_color",
      "label": "Fondo (sobreescribe el color scheme)"
    },
    {
      "type": "color",
      "id": "bar_text_color",
      "label": "Texto (sobreescribe el color scheme)"
    },
    {
      "type": "header",
      "content": "Carrusel"
    },
    {
      "type": "paragraph",
      "content": "Solo aplica cuando el modo es Carrusel."
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad de rotación",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "seg"
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de sección",
      "options": [
        { "value": "page-width", "label": "Ancho de página" },
        { "value": "full-width", "label": "Ancho completo" }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Grosor del divisor inferior",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_desktop",
      "label": "Padding lateral — desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_mobile",
      "label": "Padding lateral — mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding superior",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding inferior",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Moxie Custom Header Top Bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
