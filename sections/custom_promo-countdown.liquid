<script
  src="{{ 'custom-promo-countdown.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign s = section.settings
  assign target = s.target_date | append: 'T' | append: s.target_time | append: ':00'

  assign any_before_hours   = s.show_days
  assign any_before_minutes = s.show_days | default: false
  if s.show_hours
    assign any_before_minutes = true
  endif
  assign any_before_seconds = any_before_minutes | default: false
  if s.show_minutes
    assign any_before_seconds = true
  endif

  assign bg_style = ''
  case s.background_type
    when 'solid'
      assign bg_style = 'background-color:' | append: s.bg_color | append: ';'

    when 'gradient'
      assign bg_style = 'background:linear-gradient(' | append: s.bg_gradient_angle | append: 'deg,' | append: s.bg_gradient_from | append: ',' | append: s.bg_gradient_to | append: ');'

    when 'image'
      if s.bg_image != blank
        assign img_url = s.bg_image | image_url: width: 1920
        assign ov_a    = s.bg_overlay_opacity | divided_by: 100.0
        assign ov_rgba = 'rgba(' | append: s.bg_overlay_color.red | append: ',' | append: s.bg_overlay_color.green | append: ',' | append: s.bg_overlay_color.blue | append: ',' | append: ov_a | append: ')'
        assign bg_style = 'background:linear-gradient(' | append: ov_rgba | append: ',' | append: ov_rgba | append: '),url(' | append: img_url | append: ');background-size:cover;background-position:center;background-repeat:no-repeat;'
      endif
  endcase
-%}

<div class="custom-mox-countdown">
<promo-countdown
  id="section-{{ section.id }}"
  class="color-{{ s.color_scheme }}{% if s.layout == 'centered' %} mox-cd--centered{% endif %} custom-center-container "
  data-target="{{ target }}"
  data-hide-on-expire="{{ s.hide_on_expire }}"
  style="
    --mox-cd-pt: {{ s.padding_top }}px;
    --mox-cd-pb: {{ s.padding_bottom }}px;
    --mox-cd-digit-size: {{ s.digit_size }}px;
    --mox-cd-label-size: {{ s.label_size }}px;
    --mox-cd-text-size: {{ s.text_size }}px;
    --mox-cd-gap: {{ s.unit_gap }}px;
    {% unless s.text_color == blank %}--mox-cd-text-color: {{ s.text_color }};{% endunless %}
    {% unless s.digit_color == blank %}--mox-cd-digit-color: {{ s.digit_color }};{% endunless %}
    {% unless s.label_color == blank %}--mox-cd-label-color: {{ s.label_color }};{% endunless %}
    {% if s.text_weight != blank %}--mox-cd-text-weight: {{ s.text_weight }};{% endif %}
    {% if s.digit_weight != blank %}--mox-cd-digit-weight: {{ s.digit_weight }};{% endif %}
    {{ bg_style }}
  "
  {{ section.shopify_attributes }}
>
  <div class="mox-cd__inner page-width custom-standar-max-width">

    {%- if s.promo_text != blank -%}
      <div class="mox-cd__text">{{ s.promo_text }}</div>
    {%- endif -%}

    <div class="mox-cd__timer" aria-live="polite" aria-atomic="true">

      {%- if s.show_days -%}
        <div class="mox-cd__unit">
          <span class="mox-cd__digit" ref="days">00</span>
          {%- if s.label_days != blank -%}
            <span class="mox-cd__label">{{ s.label_days }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.show_hours -%}
        {%- if any_before_hours -%}
          <span class="mox-cd__sep" aria-hidden="true">{{ s.separator }}</span>
        {%- endif -%}
        <div class="mox-cd__unit">
          <span class="mox-cd__digit" ref="hours">00</span>
          {%- if s.label_hours != blank -%}
            <span class="mox-cd__label">{{ s.label_hours }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.show_minutes -%}
        {%- if any_before_minutes -%}
          <span class="mox-cd__sep" aria-hidden="true">{{ s.separator }}</span>
        {%- endif -%}
        <div class="mox-cd__unit">
          <span class="mox-cd__digit" ref="minutes">00</span>
          {%- if s.label_minutes != blank -%}
            <span class="mox-cd__label">{{ s.label_minutes }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.show_seconds -%}
        {%- if any_before_seconds -%}
          <span class="mox-cd__sep" aria-hidden="true">{{ s.separator }}</span>
        {%- endif -%}
        <div class="mox-cd__unit">
          <span class="mox-cd__digit" ref="seconds">00</span>
          {%- if s.label_seconds != blank -%}
            <span class="mox-cd__label">{{ s.label_seconds }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</promo-countdown>
</div>

{% schema %}
{
  "name": "Moxie Promo Countdown",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "richtext",
      "id": "promo_text",
      "label": "Texto promocional",
      "default": "<p><strong>30% OFF</strong> EN TODA LA TIENDA</p>"
    },
    {
      "type": "header",
      "content": "Fecha límite"
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "Fecha",
      "info": "Formato YYYY-MM-DD — ej. 2025-12-31",
      "default": "2025-12-31"
    },
    {
      "type": "text",
      "id": "target_time",
      "label": "Hora (24 h)",
      "info": "Formato HH:MM — ej. 23:59",
      "default": "23:59"
    },
    {
      "type": "checkbox",
      "id": "hide_on_expire",
      "label": "Ocultar sección al vencer",
      "default": false
    },
    {
      "type": "header",
      "content": "Unidades del contador"
    },
    {
      "type": "richtext",
      "id": "separator",
      "label": "Separador",
      "default": "<p>:</p>"
    },
    {
      "type": "checkbox",
      "id": "show_days",
      "label": "Mostrar días",
      "default": true
    },
    {
      "type": "richtext",
      "id": "label_days",
      "label": "Etiqueta días",
      "default": "<p>DÍAS</p>"
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Mostrar horas",
      "default": true
    },
    {
      "type": "richtext",
      "id": "label_hours",
      "label": "Etiqueta horas",
      "default": "<p>HORAS</p>"
    },
    {
      "type": "checkbox",
      "id": "show_minutes",
      "label": "Mostrar minutos",
      "default": true
    },
    {
      "type": "richtext",
      "id": "label_minutes",
      "label": "Etiqueta minutos",
      "default": "<p>MINUTOS</p>"
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "Mostrar segundos",
      "default": true
    },
    {
      "type": "richtext",
      "id": "label_seconds",
      "label": "Etiqueta segundos",
      "default": "<p>SEGUNDOS</p>"
    },
    {
      "type": "header",
      "content": "Fondo"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Tipo de fondo",
      "options": [
        { "value": "scheme", "label": "Color scheme (predeterminado)" },
        { "value": "solid", "label": "Color sólido" },
        { "value": "gradient", "label": "Degradado" },
        { "value": "image", "label": "Imagen" }
      ],
      "default": "scheme"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color sólido",
      "default": "#1E2B51"
    },
    {
      "type": "color",
      "id": "bg_gradient_from",
      "label": "Degradado — color inicial",
      "default": "#1E2B51"
    },
    {
      "type": "color",
      "id": "bg_gradient_to",
      "label": "Degradado — color final",
      "default": "#3a4f8e"
    },
    {
      "type": "range",
      "id": "bg_gradient_angle",
      "label": "Ángulo del degradado",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "°",
      "default": 90
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de fondo"
    },
    {
      "type": "color",
      "id": "bg_overlay_color",
      "label": "Color de superposición",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "bg_overlay_opacity",
      "label": "Opacidad de superposición",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color texto promo"
    },
    {
      "type": "color",
      "id": "digit_color",
      "label": "Color dígitos"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Color etiquetas (días, horas…)"
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Grosor texto promo",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extrabold (800)" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "digit_weight",
      "label": "Grosor dígitos",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extrabold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposición",
      "options": [
        { "value": "split", "label": "Texto izquierda / Timer derecha" },
        { "value": "centered", "label": "Centrado" }
      ],
      "default": "split"
    },
    {
      "type": "range",
      "id": "digit_size",
      "label": "Tamaño dígitos",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Tamaño etiquetas",
      "min": 6,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tamaño texto promo",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "unit_gap",
      "label": "Espacio entre unidades",
      "min": 2,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Moxie Promo Countdown",
      "category": "Moxie"
    }
  ]
}
{% endschema %}
