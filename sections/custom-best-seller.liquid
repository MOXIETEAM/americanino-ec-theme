{%- liquid
  assign s = section.settings
  assign collection = collections[s.collection]
-%}

<div class="custom-center-container">
<div
  class="mox-bs color-{{ s.color_scheme }} custom-standar-max-width{% if s.padding_lateral_desktop %} custom-padding-left-right-only-desktop{% endif %}{% if s.padding_lateral_mobile %} custom-padding-left-right-only-tablet-mobile{% endif %}"
  style="
    --mox-bs-pt: {{ s.padding_top }}px;
    --mox-bs-pb: {{ s.padding_bottom }}px;
    --cg-ratio: {{ s.image_ratio | default: '3/4' }};
    {% unless s.bg_color == blank %}background-color: {{ s.bg_color }};{% endunless %}
  "
  {{ section.shopify_attributes }}
>
  <div class="mox-bs__inner page-width">

    {{- '<!-- ── Header ──────────────────────────────────────────────────────────── -->' -}}
    <div class="mox-bs__header">
      <div class="mox-bs__header-text">
        {%- if s.title != blank -%}
          <h2 class="mox-bs__title">{{ s.title }}</h2>
        {%- endif -%}
        {%- if s.subtitle != blank -%}
          <p class="mox-bs__subtitle">{{ s.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if s.button_link != blank and s.button_text != blank -%}
        <a class="mox-bs__btn" href="{{ s.button_link }}">{{ s.button_text }}</a>
      {%- endif -%}
    </div>

    {{- '<!-- ── Grid ─────────────────────────────────────────────────────────────── -->' -}}
    <div class="mox-bs__grid">

      {{- '<!-- Hero -->' -}}
      {%- assign hero_tag = 'div' -%}
      {%- if s.hero_link != blank -%}
        {%- assign hero_tag = 'a' -%}
      {%- endif -%}
      <{{ hero_tag }}
        class="mox-bs__hero"
        {% if s.hero_link != blank %}href="{{ s.hero_link }}"{% endif %}
      >
        {%- if s.hero_image != blank -%}
          {{
            s.hero_image
            | image_url: width: 900
            | image_tag:
              class: 'mox-bs__hero-img',
              loading: 'lazy',
              widths: '400, 600, 800, 900',
              alt: s.hero_title
          }}
        {%- endif -%}
        {%- if s.hero_title != blank or s.hero_text != blank -%}
          <div class="mox-bs__hero-overlay">
            {%- if s.hero_title != blank -%}
              <span class="mox-bs__hero-title">{{ s.hero_title }}</span>
            {%- endif -%}
            {%- if s.hero_text != blank -%}
              <span class="mox-bs__hero-text">{{ s.hero_text }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </{{ hero_tag }}>

      {{- '<!-- Products 2×2 -->' -}}
      <div class="mox-bs__products">
        {%- if collection != blank -%}
          {%- for product in collection.products limit: 4 -%}
            {%- render 'custom_product_card',
              product: product,
              section_id: section.id,
              cuotas_text: s.installments_text,
              installments_link_url: s.installments_link_url,
              installments_link_label: s.installments_link_label,
              max_swatches: s.max_swatches
            -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="cg-card cg-card--placeholder">
              <div class="cg-card__media">
                {{ 'product-apparel-2' | placeholder_svg_tag: 'cg-card__img' }}
              </div>
              <div class="cg-card__info">
                <span class="cg-card__title">Nombre del producto</span>
                <div class="cg-card__bottom">
                  <div class="cg-card__price">
                    <span class="cg-card__price-current">$000.000</span>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</div>
</div>
{%- content_for 'blocks' -%}


{% schema %}
{
  "name": "Moxie Best Sellers",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Lorem Ipsum es simplemente el texto de relleno de"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Ver todo"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Imagen hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagen"
    },
    {
      "type": "url",
      "id": "hero_link",
      "label": "Enlace de la imagen"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Título sobre la imagen",
      "default": "Lorem ipsusom"
    },
    {
      "type": "text",
      "id": "hero_text",
      "label": "Texto sobre la imagen",
      "default": "Lorem ipsusom"
    },
    {
      "type": "header",
      "content": "Productos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "richtext",
      "id": "installments_text",
      "label": "Texto de cuotas",
      "default": "<p>0% de interés hasta 3 cuotas</p>",
      "info": "Deja vacío para ocultar. Ej: 0% de interés hasta 3 cuotas"
    },
    {
      "type": "text",
      "id": "installments_link_label",
      "label": "Texto del enlace \"ver bancos\"",
      "default": "ver bancos",
      "info": "Deja vacío para no mostrar el enlace"
    },
    {
      "type": "url",
      "id": "installments_link_url",
      "label": "Enlace de \"ver bancos\""
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Proporción de imagen",
      "options": [
        { "value": "2/3",  "label": "Retrato alto (2:3)" },
        { "value": "3/4",  "label": "Retrato (3:4)" },
        { "value": "1/1",  "label": "Cuadrado (1:1)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "max_swatches",
      "label": "Máximo de swatches visibles",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo (sobreescribe el scheme)"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_desktop",
      "label": "Padding lateral — desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_mobile",
      "label": "Padding lateral — mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    { "type": "@theme" }
  ],
  "presets": [
    {
      "name": "Moxie Best Sellers",
      "category": "Moxie"
    }
  ]
}
{% endschema %}
