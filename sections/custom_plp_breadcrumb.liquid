{%- comment -%}
  MOXIE: PLP Breadcrumb — sección independiente y reposicionable.
  Reutiliza snippets/custom_breadcrumb.liquid en "modo auto" (jerarquía vía
  metafield custom.parent_collection en la colección), igual que el breadcrumb
  de PDP (blocks/custom_pdp_breadcrumb.liquid).
{%- endcomment -%}

{%- liquid
  assign bc_class = ''
  unless section.settings.show_breadcrumb_desktop
    assign bc_class = bc_class | append: ' mox-hidden-desktop'
  endunless
  unless section.settings.show_breadcrumb_mobile
    assign bc_class = bc_class | append: ' mox-hidden-mobile'
  endunless
-%}

<div class="custom-center-container">
  <div
    class="custom-plp-breadcrumb color-{{ section.settings.color_scheme }} custom-standar-max-width{% if section.settings.padding_lateral_desktop %} custom-padding-left-right-only-desktop{% endif %}{% if section.settings.padding_lateral_mobile %} custom-padding-left-right-only-tablet-mobile{% endif %}"
    style="
      --plp-breadcrumb-pt: {{ section.settings.padding_top | default: 16 }}px;
      --plp-breadcrumb-pb: {{ section.settings.padding_bottom | default: 16 }}px;
      {%- unless section.settings.bg_color == blank %}background-color: {{ section.settings.bg_color }};{% endunless %}
    "
    {{ section.shopify_attributes }}
  >
    <div class="custom-plp-breadcrumb__inner page-width">
      {%- render 'custom_breadcrumb', collection: collection, class: bc_class -%}
    </div>
  </div>
</div>
{%- content_for 'blocks' -%}

{% schema %}
{
  "name": "Moxie PLP Breadcrumb",
  "tag": "section",
  "class": "section-wrapper",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Visibilidad"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb_desktop",
      "label": "Mostrar en desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb_mobile",
      "label": "Mostrar en móvil",
      "default": true
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo (sobreescribe el scheme)"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_desktop",
      "label": "Padding lateral — desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_mobile",
      "label": "Padding lateral — mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    { "type": "@theme" }
  ],
  "presets": [
    {
      "name": "Moxie PLP Breadcrumb",
      "category": "Moxie"
    }
  ]
}
{% endschema %}
