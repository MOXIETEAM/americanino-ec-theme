{%- comment -%} MOXIE: Custom Collection Grid — cuadrícula de productos con pestañas por colección {%- endcomment -%}

{%- liquid
  assign tab_blocks   = section.blocks | where: 'type', 'tab'
  assign show_tabs    = false
  if tab_blocks.size > 1
    assign show_tabs = true
  endif
  assign cols_desktop = section.settings.cols_desktop
  assign cols_mobile  = section.settings.cols_mobile
  assign image_ratio  = section.settings.image_ratio
  assign max_swatches = 4
-%}

<div
  class="custom-center-container cg-section"
  id="cg-{{ section.id }}"
  style="
    padding-block: {{ section.settings.padding_v }}px;
    {%- if section.settings.bg_color != blank -%}background-color: {{ section.settings.bg_color }};{%- endif -%}
    --cg-tab-color: {{ section.settings.tab_color | default: '#1a1a1a' }};
    --cg-tab-active-bg: {{ section.settings.tab_active_bg | default: '#1a1a1a' }};
    --cg-tab-active-text: {{ section.settings.tab_active_text | default: '#ffffff' }};
    --cg-cols-desktop: {{ cols_desktop }};
    --cg-cols-mobile: {{ cols_mobile }};
    --cg-ratio: {{ image_ratio }};
    --cg-col-gap: {{ section.settings.columns_gap }}px;
    --cg-row-gap: {{ section.settings.rows_gap }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="cg-inner custom-standar-max-width">

    {%- comment -%} ── Header ─────────────────────────────────────────── {%- endcomment -%}
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="cg-header">
        {%- if section.settings.title != blank -%}
          <h2 class="cg-header__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="cg-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Pestañas ──────────────────────────────────────── {%- endcomment -%}
    {%- if show_tabs -%}
      <div class="cg-tabs" role="tablist">
        {%- for tab in tab_blocks -%}
          <button
            class="cg-tab{% if forloop.first %} cg-tab--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-panel="cg-panel-{{ section.id }}-{{ tab.id }}"
            {{ tab.shopify_attributes }}
          >{{ tab.settings.label }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Paneles ───────────────────────────────────────── {%- endcomment -%}
    {%- for tab in tab_blocks -%}
      {%- assign tab_collection  = tab.settings.collection -%}
      {%- assign products_limit  = tab.settings.products_limit | default: 8 -%}

      <div
        class="cg-panel{% if forloop.first %} cg-panel--active{% endif %}"
        id="cg-panel-{{ section.id }}-{{ tab.id }}"
        role="tabpanel"
        aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
      >
        <div class="cg-grid">

          {%- if tab_collection != blank -%}
            {%- for product in tab_collection.products limit: products_limit -%}
              {%- liquid
                assign color_option = nil
                for opt in product.options_with_values
                  assign opt_lower = opt.name | downcase
                  if opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'color swatch'
                    assign color_option = opt
                    break
                  endif
                endfor

                assign has_discount = false
                assign discount_pct = 0
                if product.compare_at_price > product.price
                  assign has_discount = true
                  assign diff = product.compare_at_price | minus: product.price
                  assign discount_pct = diff | times: 100.0 | divided_by: product.compare_at_price | round
                endif

                assign is_new = false
                for tag in product.tags
                  assign tag_lower = tag | downcase | strip
                  if tag_lower == 'new' or tag_lower == 'nuevo'
                    assign is_new = true
                    break
                  endif
                endfor

                assign size_opt_idx = nil
                for opt in product.options
                  assign opt_lower = opt | downcase
                  if opt_lower == 'talla' or opt_lower == 'talle' or opt_lower == 'size' or opt_lower == 'tamaño'
                    assign size_opt_idx = forloop.index0
                    break
                  endif
                endfor
              -%}

              <div class="cg-card">

                {%- comment -%} Imagen + quick-add ───────────────────── {%- endcomment -%}
                <div class="cg-card__media">
                  <a href="{{ product.url }}" class="cg-card__media-link" tabindex="-1" aria-hidden="true">
                    {%- if product.featured_media -%}
                      {{
                        product.featured_media.preview_image
                        | image_url: width: 800
                        | image_tag:
                          loading: 'lazy',
                          alt: product.title,
                          class: 'cg-card__img',
                          widths: '300, 500, 800',
                          sizes: '(min-width: 990px) 25vw, 50vw'
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'cg-card__img cg-card__img--placeholder' }}
                    {%- endif -%}
                  </a>

                  {%- if has_discount or is_new -%}
                    <div class="cg-card__badges">
                      {%- if has_discount -%}
                        <span class="cg-badge cg-badge--sale">{{ discount_pct }}%OFF</span>
                      {%- endif -%}
                      {%- if is_new -%}
                        <span class="cg-badge cg-badge--new">NEW</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  {%- if size_opt_idx != nil -%}
                    {%- comment -%} Tallas: resuelve pills una sola vez ── {%- endcomment -%}
                    {%- assign shown_sizes = '' -%}

                    {%- comment -%} Desktop: strip en hover ─────────────── {%- endcomment -%}
                    <div
                      class="cg-quick"
                      role="group"
                      aria-label="Seleccionar talla — {{ product.title | escape }}"
                    >
                      <div class="cg-quick__pills">
                        {%- for variant in product.variants -%}
                          {%- assign size_val  = variant.options[size_opt_idx] -%}
                          {%- assign size_mark = size_val | prepend: '«' | append: '»' -%}
                          {%- unless shown_sizes contains size_mark -%}
                            {%- assign shown_sizes = shown_sizes | append: size_mark -%}
                            {%- assign first_vid  = nil -%}
                            {%- assign size_avail = false -%}
                            {%- for v in product.variants -%}
                              {%- if v.options[size_opt_idx] == size_val -%}
                                {%- if first_vid == nil -%}{%- assign first_vid = v.id -%}{%- endif -%}
                                {%- if v.available and size_avail == false -%}
                                  {%- assign first_vid = v.id -%}
                                  {%- assign size_avail = true -%}
                                {%- endif -%}
                              {%- endif -%}
                            {%- endfor -%}
                            <button
                              class="cg-quick__pill{% unless size_avail %} cg-quick__pill--out{% endunless %}"
                              data-variant="{{ first_vid }}"
                              {% unless size_avail %}disabled{% endunless %}
                              aria-label="Talla {{ size_val }}"
                            >{{ size_val }}</button>
                          {%- endunless -%}
                        {%- endfor -%}
                      </div>
                      <button class="cg-quick__add" disabled aria-label="Agregar al carrito">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="15" height="15">
                          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                          <line x1="3" y1="6" x2="21" y2="6"/>
                          <path d="M16 10a4 4 0 0 1-8 0"/>
                        </svg>
                      </button>
                    </div>

                    {%- comment -%} Mobile: template con pills + botón + ── {%- endcomment -%}
                    <template id="cg-tpl-{{ product.id }}-{{ section.id }}">
                      {%- assign shown_sizes = '' -%}
                      {%- for variant in product.variants -%}
                        {%- assign size_val  = variant.options[size_opt_idx] -%}
                        {%- assign size_mark = size_val | prepend: '«' | append: '»' -%}
                        {%- unless shown_sizes contains size_mark -%}
                          {%- assign shown_sizes = shown_sizes | append: size_mark -%}
                          {%- assign first_vid  = nil -%}
                          {%- assign size_avail = false -%}
                          {%- for v in product.variants -%}
                            {%- if v.options[size_opt_idx] == size_val -%}
                              {%- if first_vid == nil -%}{%- assign first_vid = v.id -%}{%- endif -%}
                              {%- if v.available and size_avail == false -%}
                                {%- assign first_vid = v.id -%}
                                {%- assign size_avail = true -%}
                              {%- endif -%}
                            {%- endif -%}
                          {%- endfor -%}
                          <button
                            class="cg-sheet__pill{% unless size_avail %} cg-sheet__pill--out{% endunless %}"
                            data-variant="{{ first_vid }}"
                            {% unless size_avail %}disabled{% endunless %}
                          >{{ size_val }}</button>
                        {%- endunless -%}
                      {%- endfor -%}
                    </template>

                    <button
                      class="cg-quick__plus"
                      aria-label="Seleccionar talla para {{ product.title | escape }}"
                      data-tpl="cg-tpl-{{ product.id }}-{{ section.id }}"
                      data-section="{{ section.id }}"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" width="16" height="16">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                    </button>
                  {%- endif -%}

                </div>

                {%- comment -%} Info ─────────────────────────────────── {%- endcomment -%}
                <div class="cg-card__info">
                  {%- if section.settings.cuotas_text != blank -%}
                    <p class="cg-card__cuotas">{{ section.settings.cuotas_text }}</p>
                  {%- endif -%}

                  <a href="{{ product.url }}" class="cg-card__title">{{ product.title | truncate: 55 }}</a>

                  <div class="cg-card__bottom">
                    <div class="cg-card__price">
                      {%- if has_discount -%}
                        <s class="cg-card__price-compare">{{ product.compare_at_price | money }}</s>
                      {%- endif -%}
                      <span class="cg-card__price-current">{{ product.price | money }}</span>
                    </div>

                    {%- if color_option != blank -%}
                      <div class="cg-card__swatches">
                        {%- assign swatch_count  = color_option.values.size -%}
                        {%- assign hidden_count  = 0 -%}
                        {%- if swatch_count > max_swatches -%}
                          {%- assign hidden_count = swatch_count | minus: max_swatches -%}
                        {%- endif -%}
                        {%- for value in color_option.values limit: max_swatches -%}
                          {%- render 'swatch', swatch: value.swatch, label: value.name -%}
                        {%- endfor -%}
                        {%- if hidden_count > 0 -%}
                          <span class="cg-card__swatch-more">+{{ hidden_count }}</span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>

              </div>
            {%- endfor -%}

          {%- else -%}
            {%- comment -%} Placeholder cuando no hay colección {%- endcomment -%}
            {%- for i in (1..products_limit) -%}
              <div class="cg-card cg-card--placeholder">
                <div class="cg-card__media">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'cg-card__img' }}
                </div>
                <div class="cg-card__info">
                  {%- if section.settings.cuotas_text != blank -%}
                    <p class="cg-card__cuotas">{{ section.settings.cuotas_text }}</p>
                  {%- endif -%}
                  <span class="cg-card__title">Nombre del producto</span>
                  <div class="cg-card__bottom">
                    <span class="cg-card__price-current">$000.000</span>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>
    {%- endfor -%}

  </div>
</div>

{%- comment -%} Mobile: bottom sheet singleton de tallas {%- endcomment -%}
<div class="cg-backdrop" id="cg-backdrop-{{ section.id }}" aria-hidden="true"></div>
<div
  class="cg-size-sheet"
  id="cg-sheet-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Seleccionar talla"
  aria-hidden="true"
>
  <div class="cg-size-sheet__bar" aria-hidden="true"></div>
  <p class="cg-size-sheet__title">SELECCIONA TU TALLA</p>
  <div class="cg-size-sheet__pills" id="cg-sheet-pills-{{ section.id }}"></div>
</div>

{% stylesheet %}
  /* ── Contenedor ── */
  .cg-section {
    box-sizing: border-box;
  }

  .cg-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Header ── */
  .cg-header {
    display: flex;
    flex-direction: column;
   
  }

  .cg-header__title {
    margin: 0;
    font-size: 32px;
    font-weight: 500;
    line-height: 38px;
    color: #1E2B51;
    text-transform: none;
  }

  .cg-header__subtitle {
    margin: 0;
    font-size: 15px;
    font-weight: 300;
    line-height: 18px;
    color: #1E2B51;
  }

  /* ── Tabs ── */
  .cg-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cg-tab {
    padding: 8px 20px;
    border: 1.5px solid var(--cg-tab-color);
    border-radius: 999px;
    background: transparent;
    color: var(--cg-tab-color);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    line-height: 1;
    max-height: 31px;
  }

  .cg-tab--active,
  .cg-tab:hover {
    background: var(--cg-tab-active-bg);
    color: var(--cg-tab-active-text);
    border-color: var(--cg-tab-active-bg);
  }

  /* ── Paneles ── */
  .cg-panel {
    display: none;
  }

  .cg-panel--active {
    display: block;
  }

  /* ── Grid ── */
  .cg-grid {
    display: grid;
    grid-template-columns: repeat(var(--cg-cols-mobile), 1fr);
    column-gap: var(--cg-col-gap);
    row-gap: var(--cg-row-gap);
  }

  @media screen and (min-width: 750px) {
    .cg-grid {
      grid-template-columns: repeat(var(--cg-cols-desktop), 1fr);
    }
  }

  /* ── Tarjeta ── */
  .cg-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cg-card__media {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background: #f0f0f0;
  }

  .cg-card__media-link {
    display: block;
    aspect-ratio: var(--cg-ratio);
  }

  .cg-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .cg-card:hover .cg-card__img {
    transform: scale(1.03);
  }

  /* ── Badges ── */
  .cg-card__badges {
    position: absolute;
    top: 8px;
    left: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 1;
  }

  .cg-badge {
    display: inline-block;
    padding: 3px 7px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border-radius: 2px;
    line-height: 1.4;
  }

  .cg-badge--sale {
    background: #1a2a4a;
    color: #fff;
  }

  .cg-badge--new {
    background: #e8e8e8;
    color: #1a1a1a;
  }

  /* ── Desktop: strip en hover ── */
  .cg-quick {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    display: none; /* solo desktop */
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 11px 10px;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.22s ease, transform 0.22s ease;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .cg-quick {
      display: grid;
    }
    .cg-card:hover .cg-quick,
    .cg-card:focus-within .cg-quick {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  .cg-quick__pills {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 0;
  }

  .cg-quick__pill {
    flex: 1;
    text-align: center;
    padding: 4px 2px;
    border: none;
    border-radius: 0;
    background: transparent;
    color: #999;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    cursor: pointer;
    line-height: 1;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .cg-quick__pill--out {
    color: #ccc;
    text-decoration: line-through;
    cursor: default;
  }

  .cg-quick__pill--selected {
    color: #1a1a1a;
    font-weight: 600;
  }

  .cg-quick__pill:not(.cg-quick__pill--out):not(.cg-quick__pill--selected):hover {
    color: #444;
  }

  .cg-quick__add {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 2px;
    background: #1a1a1a;
    color: #fff;
    cursor: pointer;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.18s ease, transform 0.18s ease, background 0.2s;
    pointer-events: none;
  }

  .cg-quick__add:not(:disabled) {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  .cg-quick__add--loading { opacity: 0.6 !important; }
  .cg-quick__add--success { background: #2a7a2a; }

  /* ── Mobile: botón + ── */
  .cg-quick__plus {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .cg-quick__plus {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      bottom: 10px;
      right: 10px;
      z-index: 2;
      width: 34px;
      height: 34px;
      border: none;
      border-radius: 50%;
      background: #fff;
      color: #1a1a1a;
      cursor: pointer;
      box-shadow: 0 1px 8px rgba(0, 0, 0, 0.18);
    }
  }

  /* ── Mobile: bottom sheet ── */
  .cg-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .cg-size-sheet {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 201;
    background: #fff;
    border-radius: 16px 16px 0 0;
    padding: 10px 20px 36px;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }

  @media screen and (max-width: 749px) {
    .cg-backdrop { display: block; }
    .cg-size-sheet { display: block; }
  }

  .cg-backdrop--open {
    opacity: 1;
    pointer-events: auto;
  }

  .cg-size-sheet--open {
    transform: translateY(0);
  }

  .cg-size-sheet__bar {
    width: 36px;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    margin: 0 auto 18px;
  }

  .cg-size-sheet__title {
    margin: 0 0 14px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #1a1a1a;
  }

  .cg-size-sheet__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .cg-sheet__pill {
    min-width: 50px;
    padding: 11px 14px;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #fff;
    color: #1a1a1a;
    font-size: 0.85rem;
    font-weight: 400;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .cg-sheet__pill--out {
    opacity: 0.38;
    text-decoration: line-through;
    cursor: default;
  }

  .cg-sheet__pill--selected {
    border-color: #1a1a1a;
    background: #1a1a1a;
    color: #fff;
  }

  .cg-sheet__pill:not(.cg-sheet__pill--out):not(.cg-sheet__pill--selected):hover {
    border-color: #999;
  }

  /* Estado de carga en la pill seleccionada */
  .cg-sheet__pill--selected:disabled {
    opacity: 0.6;
    cursor: default;
  }

  /* ── Info ── */
  .cg-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-inline: 2px;
  }

  .cg-card__cuotas {
    margin: 0;
    font-size: 0.68rem;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    line-height: 1.3;
  }

  .cg-card__title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.8rem;
    font-weight: 400;
    color: inherit;
    text-decoration: none;
    line-height: 1.35;
  }

  .cg-card__title:hover {
    text-decoration: underline;
  }

  .cg-card__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: 2px;
  }

  /* ── Precios ── */
  .cg-card__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px 6px;
  }

  .cg-card__price-compare {
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    text-decoration: line-through;
  }

  .cg-card__price-current {
    font-size: 0.875rem;
    font-weight: 600;
    color: inherit;
  }

  /* ── Swatches ── */
  .cg-card__swatches {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .cg-card__swatches .swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1.5px solid rgb(var(--color-foreground-rgb) / 0.15);
    flex-shrink: 0;
  }

  .cg-card__swatch-more {
    font-size: 0.7rem;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    font-weight: 500;
  }

  /* ── Placeholder ── */
  .cg-card--placeholder .cg-card__media {
    aspect-ratio: var(--cg-ratio);
  }

  .cg-card--placeholder .cg-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .cg-card__img,
    .cg-quick,
    .cg-quick__add,
    .cg-size-sheet,
    .cg-backdrop {
      transition: none;
    }
  }
{% endstylesheet %}

<script>
(function () {
  var section  = document.getElementById('cg-{{ section.id }}');
  var backdrop = document.getElementById('cg-backdrop-{{ section.id }}');
  var sheet    = document.getElementById('cg-sheet-{{ section.id }}');
  var sheetPills = document.getElementById('cg-sheet-pills-{{ section.id }}');
  if (!section) return;

  var CART_URL = (window.Theme && window.Theme.routes && window.Theme.routes.cart_add_url) || '/cart/add.js';
  var ICON_CART = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="15" height="15"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>';
  var ICON_OK   = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" width="15" height="15"><polyline points="20 6 9 17 4 12"/></svg>';

  /* ── Util: add to cart ─────────────────────────────────────────────── */
  function addToCart(variantId, btnEl, onSuccess) {
    btnEl.disabled = true;
    btnEl.classList.add('cg-adding');
    fetch(CART_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: Number(variantId), quantity: 1 })
    })
    .then(function (res) { if (!res.ok) throw new Error(); return res.json(); })
    .then(function (cart) {
      btnEl.classList.remove('cg-adding');
      document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { source: 'collection-grid', cart: cart } }));
      onSuccess(cart);
    })
    .catch(function () {
      btnEl.classList.remove('cg-adding');
      btnEl.disabled = false;
    });
  }

  /* ── Tab switching ─────────────────────────────────────────────────── */
  section.querySelectorAll('.cg-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var panelId = btn.dataset.panel;
      section.querySelectorAll('.cg-tab').forEach(function (b) {
        b.classList.toggle('cg-tab--active', b === btn);
        b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
      });
      section.querySelectorAll('.cg-panel').forEach(function (p) {
        var active = p.id === panelId;
        p.classList.toggle('cg-panel--active', active);
        p.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
    });
  });

  /* ── Desktop: strip hover ─────────────────────────────────────────── */
  section.querySelectorAll('.cg-card').forEach(function (card) {
    var quick  = card.querySelector('.cg-quick');
    if (!quick) return;
    var pills  = quick.querySelectorAll('.cg-quick__pill');
    var addBtn = quick.querySelector('.cg-quick__add');
    var selId  = null;

    pills.forEach(function (pill) {
      pill.addEventListener('click', function (e) {
        e.preventDefault(); e.stopPropagation();
        pills.forEach(function (p) { p.classList.remove('cg-quick__pill--selected'); });
        pill.classList.add('cg-quick__pill--selected');
        selId = pill.dataset.variant;
        addBtn.disabled = false;
      });
    });

    addBtn.addEventListener('click', function (e) {
      e.preventDefault(); e.stopPropagation();
      if (!selId) return;
      addToCart(selId, addBtn, function () {
        addBtn.innerHTML = ICON_OK;
        addBtn.classList.add('cg-quick__add--success');
        setTimeout(function () {
          addBtn.classList.remove('cg-quick__add--success');
          addBtn.innerHTML = ICON_CART;
          addBtn.disabled = true;
          pills.forEach(function (p) { p.classList.remove('cg-quick__pill--selected'); });
          selId = null;
          addBtn.disabled = true;
        }, 2200);
      });
    });
  });

  /* ── Mobile: bottom sheet ─────────────────────────────────────────── */
  if (!sheet || !backdrop || !sheetPills) return;

  function openSheet(tplId) {
    var tpl = document.getElementById(tplId);
    if (!tpl) return;

    /* Poblar pills desde template */
    sheetPills.innerHTML = '';
    sheetPills.appendChild(tpl.content.cloneNode(true));

    /* Al tocar una talla → add to cart inmediato */
    sheetPills.querySelectorAll('.cg-sheet__pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        if (pill.disabled) return;

        /* Feedback visual: seleccionada */
        sheetPills.querySelectorAll('.cg-sheet__pill').forEach(function (p) {
          p.classList.remove('cg-sheet__pill--selected');
          p.disabled = true;
        });
        pill.classList.add('cg-sheet__pill--selected');

        addToCart(pill.dataset.variant, pill, function () {
          setTimeout(closeSheet, 900);
        });
      });
    });

    sheet.setAttribute('aria-hidden', 'false');
    backdrop.classList.add('cg-backdrop--open');
    sheet.classList.add('cg-size-sheet--open');
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    sheet.setAttribute('aria-hidden', 'true');
    backdrop.classList.remove('cg-backdrop--open');
    sheet.classList.remove('cg-size-sheet--open');
    document.body.style.overflow = '';
  }

  /* Botón + */
  section.querySelectorAll('.cg-quick__plus').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault(); e.stopPropagation();
      openSheet(btn.dataset.tpl);
    });
  });

  /* Backdrop click → close */
  backdrop.addEventListener('click', closeSheet);

  /* Escape → close */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeSheet();
  });
})();
</script>

