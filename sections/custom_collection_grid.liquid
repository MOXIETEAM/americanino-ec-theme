{%- comment -%} MOXIE: Custom Collection Grid — cuadrícula de productos con pestañas por colección {%- endcomment -%}

{%- liquid
  assign tab_blocks   = section.blocks | where: 'type', 'tab'
  assign show_tabs    = false
  if tab_blocks.size > 1
    assign show_tabs = true
  endif
  assign cols_desktop  = section.settings.cols_desktop
  assign cols_mobile   = section.settings.cols_mobile
  assign image_ratio   = section.settings.image_ratio | default: '3/4'
  assign max_swatches  = 4
-%}

<div
  class="custom-center-container cg-section"
  id="cg-{{ section.id }}"
  style="
    padding-block: {{ section.settings.padding_v }}px;
    {%- if section.settings.bg_color != blank -%}background-color: {{ section.settings.bg_color }};{%- endif -%}
    --cg-tab-color: {{ section.settings.tab_color | default: '#1a1a1a' }};
    --cg-tab-active-bg: {{ section.settings.tab_active_bg | default: '#1a1a1a' }};
    --cg-tab-active-text: {{ section.settings.tab_active_text | default: '#ffffff' }};
    --cg-ratio: {{ image_ratio }};
    --cg-cols-desktop: {{ cols_desktop }};
    --cg-cols-mobile: {{ cols_mobile }};
    --cg-col-gap: {{ section.settings.columns_gap }}px;
    --cg-row-gap: {{ section.settings.rows_gap }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="cg-inner custom-standar-max-width{% if section.settings.padding_lateral_desktop %} custom-padding-left-right-only-desktop{% endif %}{% if section.settings.padding_lateral_mobile %} custom-padding-left-right-only-tablet-mobile{% endif %}">

    {%- comment -%} ── Header ─────────────────────────────────────────── {%- endcomment -%}
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="cg-header">
        {%- if section.settings.title != blank -%}
          <h2 class="cg-header__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="cg-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Pestañas ──────────────────────────────────────── {%- endcomment -%}
    {%- if show_tabs -%}
      <div class="cg-tabs" role="tablist">
        {%- for tab in tab_blocks -%}
          <button
            class="cg-tab{% if forloop.first %} cg-tab--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-panel="cg-panel-{{ section.id }}-{{ tab.id }}"
            {{ tab.shopify_attributes }}
          >{{ tab.settings.label }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Paneles ───────────────────────────────────────── {%- endcomment -%}
    {%- for tab in tab_blocks -%}
      {%- assign tab_collection  = tab.settings.collection -%}
      {%- assign products_limit  = tab.settings.products_limit | default: 8 -%}

      <div
        class="cg-panel{% if forloop.first %} cg-panel--active{% endif %}"
        id="cg-panel-{{ section.id }}-{{ tab.id }}"
        role="tabpanel"
        aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
      >
        <div class="cg-grid">

          {%- if tab_collection != blank -%}
            {%- for product in tab_collection.products limit: products_limit -%}
              {%- render 'custom_product_card',
                product: product,
                section_id: section.id,
                cuotas_text: section.settings.cuotas_text,
                max_swatches: max_swatches
              -%}
            {%- endfor -%}

          {%- else -%}
            {%- comment -%} Placeholder cuando no hay colección {%- endcomment -%}
            {%- for i in (1..products_limit) -%}
              <div class="cg-card cg-card--placeholder">
                <div class="cg-card__media">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'cg-card__img' }}
                </div>
                <div class="cg-card__info">
                  {%- if section.settings.cuotas_text != blank -%}
                    <p class="cg-card__cuotas">{{ section.settings.cuotas_text }}</p>
                  {%- endif -%}
                  <span class="cg-card__title">Nombre del producto</span>
                  <div class="cg-card__bottom">
                    <div class="cg-card__price">
                      <span class="cg-card__price-current">$000.000</span>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>
    {%- endfor -%}

  </div>
</div>


{% stylesheet %}
  /* ── Contenedor ── */
  .cg-section {
    box-sizing: border-box;
  }

  .cg-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Header ── */
  .cg-header {
    display: flex;
    flex-direction: column;
   
  }

  .cg-header__title {
    margin: 0;
    font-size: 32px;
    font-weight: 500;
    line-height: 38px;
    color: #1E2B51;
    text-transform: none;
  }

  .cg-header__subtitle {
    margin: 0;
    font-size: 15px;
    font-weight: 300;
    line-height: 18px;
    color: #1E2B51;
  }

  /* ── Tabs ── */
  .cg-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cg-tab {
    padding: 8px 20px;
    border: 1.5px solid var(--cg-tab-color);
    border-radius: 999px;
    background: transparent;
    color: var(--cg-tab-color);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    line-height: 1;
    max-height: 31px;
  }

  .cg-tab--active,
  .cg-tab:hover {
    background: var(--cg-tab-active-bg);
    color: var(--cg-tab-active-text);
    border-color: var(--cg-tab-active-bg);
  }

  /* ── Paneles ── */
  .cg-panel {
    display: none;
  }

  .cg-panel--active {
    display: block;
  }

  /* ── Grid ── */
  .cg-grid {
    display: grid;
    grid-template-columns: repeat(var(--cg-cols-mobile), 1fr);
    column-gap: var(--cg-col-gap);
    row-gap: var(--cg-row-gap);
  }

  @media screen and (min-width: 750px) {
    .cg-grid {
      grid-template-columns: repeat(var(--cg-cols-desktop), 1fr);
    }
  }
{% endstylesheet %}

<script>
(function () {
  var section = document.getElementById('cg-{{ section.id }}');
  if (!section) return;

  section.querySelectorAll('.cg-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var panelId = btn.dataset.panel;
      section.querySelectorAll('.cg-tab').forEach(function (b) {
        b.classList.toggle('cg-tab--active', b === btn);
        b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
      });
      section.querySelectorAll('.cg-panel').forEach(function (p) {
        var active = p.id === panelId;
        p.classList.toggle('cg-panel--active', active);
        p.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Moxie Collection Grid",
  "tag": "section",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "tab",
      "name": "Pestaña de colección",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta de la pestaña",
          "default": "Hombre"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección"
        },
        {
          "type": "range",
          "id": "products_limit",
          "label": "Productos a mostrar",
          "min": 4,
          "max": 24,
          "step": 4,
          "default": 8
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Nueva colección"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo"
    },
    {
      "type": "header",
      "content": "Pestañas"
    },
    {
      "type": "color",
      "id": "tab_color",
      "label": "Color texto y borde",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Fondo pestaña activa",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_active_text",
      "label": "Texto pestaña activa",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Cuadrícula"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Proporción de imagen",
      "options": [
        { "value": "2/3",  "label": "Retrato alto (2:3)" },
        { "value": "3/4",  "label": "Retrato (3:4)" },
        { "value": "1/1",  "label": "Cuadrado (1:1)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "label": "Columnas en desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cols_mobile",
      "label": "Columnas en mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Separación horizontal",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "Separación vertical",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Cuotas"
    },
    {
      "type": "text",
      "id": "cuotas_text",
      "label": "Texto de cuotas",
      "default": "0% de interés hasta 3 cuotas ver bancos"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_desktop",
      "label": "Padding lateral — desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "padding_lateral_mobile",
      "label": "Padding lateral — mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo"
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Relleno vertical",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Moxie Collection Grid",
      "category": "Moxie",
      "settings": {
        "title": "Nueva colección",
        "cols_desktop": 4,
        "cols_mobile": 2,
        "image_ratio": "3/4",
        "columns_gap": 12,
        "rows_gap": 24,
        "cuotas_text": "0% de interés hasta 3 cuotas ver bancos",
        "padding_v": 56
      },
      "blocks": [
        { "type": "tab", "settings": { "label": "Hombre", "products_limit": 8 } },
        { "type": "tab", "settings": { "label": "Mujer",  "products_limit": 8 } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
