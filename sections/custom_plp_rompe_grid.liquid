{%- comment -%}
  MOXIE: PLP Rompe-Grid
  Metaobjeto: banner_rompegrids_plp
  Metacampo en coleccion: custom.mox_plp_banners_rompegrids (lista de referencias a banner_rompegrids_plp)

  Claves de campo del metaobjeto:
    donde_mostrar           → texto
    imagen                  → archivo (imagen)
    titulo                  → texto corto
    descripcion             → texto multilinea
    texto_del_boton         → texto corto
    url_del_boton           → enlace (URL)
    url_del_banner          → enlace (URL) — si tiene valor, TODO el banner es clickeable (solo sin pines)
    color_de_fondo_cuando_no_hay_imagen → color
    color_de_texto          → color
    posicion                → entero (despues de cual producto insertar, 1-based)
    columnas_a_ocupar       → lista de opciones: "1" | "2"

    — Pines de producto (hasta 5) —
    pin_1_producto          → referencia a producto
    pin_1_pos_x             → entero 0-100 (% desde la izquierda)
    pin_1_pos_y             → entero 0-100 (% desde arriba)
    pin_2_producto / pin_2_pos_x / pin_2_pos_y
    pin_3_producto / pin_3_pos_x / pin_3_pos_y
    pin_4_producto / pin_4_pos_x / pin_4_pos_y
    pin_5_producto / pin_5_pos_x / pin_5_pos_y
{%- endcomment -%}

{%- liquid
  assign plp_banners = collection.metafields.custom.mox_plp_banners_rompegrids.value
-%}

{%- comment -%} ── DEBUG: activo con ?moxie_debug=1 en la URL ── {%- endcomment -%}
{%- if request.query_string contains 'moxie_debug=1' -%}
<div style="background:#1e1e1e;color:#d4d4d4;font-family:monospace;font-size:12px;padding:16px;margin:8px;border-radius:8px;white-space:pre-wrap;z-index:9999;position:relative;">
<strong style="color:#4ec9b0;">MOXIE ROMPE-GRID DEBUG</strong>

<strong style="color:#9cdcfe;">Coleccion:</strong> {{ collection.title }} ({{ collection.handle }})
<strong style="color:#9cdcfe;">Metacampo custom.mox_plp_banners_rompegrids:</strong>
{%- if plp_banners != blank -%}
  {{ plp_banners.size }} banner(s) encontrado(s)
{%- else -%}
  <span style="color:#f44747;">VACIO — el metacampo no esta asignado a esta coleccion o la clave es incorrecta</span>
{%- endif -%}

{%- if plp_banners != blank -%}
  {%- for banner in plp_banners -%}
<hr style="border-color:#444;margin:8px 0;">
<strong style="color:#dcdcaa;">Banner {{ forloop.index }}</strong>
  donde_mostrar     = {{ banner.donde_mostrar.value | json }}
  posicion          = {{ banner.posicion.value | json }}
  columnas_a_ocupar = {{ banner.columnas_a_ocupar.value | json }}
  imagen (blank?)   = {{ banner.imagen.value | json }}
  titulo            = {{ banner.titulo.value | json }}
  descripcion       = {{ banner.descripcion.value | json }}
  texto_del_boton   = {{ banner.texto_del_boton.value | json }}
  url_del_boton (raw)   = {{ banner.url_del_boton.value | json }}
  url_del_banner (raw)  = {{ banner.url_del_banner.value | json }}
  bg_color          = {{ banner.color_de_fondo_cuando_no_hay_imagen.value | json }}
  text_color        = {{ banner.color_de_texto.value | json }}
  pin_1_producto    = {{ banner.pin_1_producto.value.title | json }}
  pin_2_producto    = {{ banner.pin_2_producto.value.title | json }}
  pin_3_producto    = {{ banner.pin_3_producto.value.title | json }}
  pin_4_producto    = {{ banner.pin_4_producto.value.title | json }}
  pin_5_producto    = {{ banner.pin_5_producto.value.title | json }}
  {%- endfor -%}
{%- endif -%}
</div>
{%- endif -%}

{%- comment -%} Placeholder visible solo en el editor de Shopify {%- endcomment -%}
{% comment %} {%- if request.design_mode -%}
  <div class="plp-rompe-grid__editor-placeholder">
    <strong>Moxie PLP Rompe-Grid</strong><br>
    Los banners se configuran desde el metacampo <code>custom.mox_plp_banners_rompegrids</code> de cada coleccion (metaobjeto <code>banner_rompegrids_plp</code>).
    {%- if plp_banners != blank -%}
      <br>✓ {{ plp_banners.size }} banner(s) configurado(s) para esta coleccion.
    {%- else -%}
      <br>Sin banners configurados para esta coleccion.
    {%- endif -%}
  </div>
{%- endif -%} {% endcomment %}

{%- comment -%} Serializar datos de banners como JSON para el JS {%- endcomment -%}
{%- if plp_banners != blank and plp_banners.size > 0 -%}
<script id="plp-rompe-grid-data-{{ section.id }}" type="application/json">
[
  {%- for banner in plp_banners -%}
    {%- comment -%}
      url_del_boton / url_del_banner pueden ser campo "URL" (value = string)
      o campo "Enlace" (value = {url:, text:}) — se normalizan a string plano.
    {%- endcomment -%}
    {%- assign _url_boton_final  = banner.url_del_boton.value.url  | default: banner.url_del_boton.value -%}
    {%- assign _url_banner_final = banner.url_del_banner.value.url | default: banner.url_del_banner.value -%}
  {
    "donde_mostrar": {{ banner.donde_mostrar.value | json }},
    "posicion":      {{ banner.posicion.value | default: 2 | json }},
    "columnas":      {{ banner.columnas_a_ocupar.value | default: '2' | json }},
    "imagen":        {%- if banner.imagen.value != blank -%}{{ banner.imagen.value | image_url: width: 1400 | json }}{%- else -%}null{%- endif -%},
    "imagen_alt":    {{ banner.imagen.value.alt | default: '' | json }},
    "titulo":        {{ banner.titulo.value | json }},
    "descripcion":   {{ banner.descripcion.value | json }},
    "texto_boton":   {{ banner.texto_del_boton.value | json }},
    "url_boton":     {{ _url_boton_final | json }},
    "url_del_banner": {{ _url_banner_final | json }},
    "bg_color":      {{ banner.color_de_fondo_cuando_no_hay_imagen.value | json }},
    "text_color":    {{ banner.color_de_texto.value | json }},
    "pins": [
      {%- assign pin_sep = '' -%}

      {%- assign p = banner.pin_1_producto.value -%}
      {%- if p != blank -%}
      {{ pin_sep }}{"x":{{ banner.pin_1_pos_x.value | default: 25 }},"y":{{ banner.pin_1_pos_y.value | default: 50 }},"title":{{ p.title | json }},"price":{{ p.price | money | json }},"compare_price":{%- if p.compare_at_price > p.price -%}{{ p.compare_at_price | money | json }}{%- else -%}null{%- endif -%},"image":{%- if p.featured_image -%}{{ p.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},"alt":{{ p.featured_image.alt | default: p.title | json }},"url":{{ p.url | json }},"option_name":{{ p.options.first | json }},"variants":[{%- for v in p.variants -%}{%- unless forloop.first -%},{%- endunless -%}{"id":{{ v.id }},"title":{{ v.title | json }},"option1":{{ v.option1 | json }},"available":{{ v.available }}}{%- endfor -%}]}
      {%- assign pin_sep = ',' -%}
      {%- endif -%}

      {%- assign p = banner.pin_2_producto.value -%}
      {%- if p != blank -%}
      {{ pin_sep }}{"x":{{ banner.pin_2_pos_x.value | default: 50 }},"y":{{ banner.pin_2_pos_y.value | default: 50 }},"title":{{ p.title | json }},"price":{{ p.price | money | json }},"compare_price":{%- if p.compare_at_price > p.price -%}{{ p.compare_at_price | money | json }}{%- else -%}null{%- endif -%},"image":{%- if p.featured_image -%}{{ p.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},"alt":{{ p.featured_image.alt | default: p.title | json }},"url":{{ p.url | json }},"option_name":{{ p.options.first | json }},"variants":[{%- for v in p.variants -%}{%- unless forloop.first -%},{%- endunless -%}{"id":{{ v.id }},"title":{{ v.title | json }},"option1":{{ v.option1 | json }},"available":{{ v.available }}}{%- endfor -%}]}
      {%- assign pin_sep = ',' -%}
      {%- endif -%}

      {%- assign p = banner.pin_3_producto.value -%}
      {%- if p != blank -%}
      {{ pin_sep }}{"x":{{ banner.pin_3_pos_x.value | default: 75 }},"y":{{ banner.pin_3_pos_y.value | default: 50 }},"title":{{ p.title | json }},"price":{{ p.price | money | json }},"compare_price":{%- if p.compare_at_price > p.price -%}{{ p.compare_at_price | money | json }}{%- else -%}null{%- endif -%},"image":{%- if p.featured_image -%}{{ p.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},"alt":{{ p.featured_image.alt | default: p.title | json }},"url":{{ p.url | json }},"option_name":{{ p.options.first | json }},"variants":[{%- for v in p.variants -%}{%- unless forloop.first -%},{%- endunless -%}{"id":{{ v.id }},"title":{{ v.title | json }},"option1":{{ v.option1 | json }},"available":{{ v.available }}}{%- endfor -%}]}
      {%- assign pin_sep = ',' -%}
      {%- endif -%}

      {%- assign p = banner.pin_4_producto.value -%}
      {%- if p != blank -%}
      {{ pin_sep }}{"x":{{ banner.pin_4_pos_x.value | default: 35 }},"y":{{ banner.pin_4_pos_y.value | default: 70 }},"title":{{ p.title | json }},"price":{{ p.price | money | json }},"compare_price":{%- if p.compare_at_price > p.price -%}{{ p.compare_at_price | money | json }}{%- else -%}null{%- endif -%},"image":{%- if p.featured_image -%}{{ p.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},"alt":{{ p.featured_image.alt | default: p.title | json }},"url":{{ p.url | json }},"option_name":{{ p.options.first | json }},"variants":[{%- for v in p.variants -%}{%- unless forloop.first -%},{%- endunless -%}{"id":{{ v.id }},"title":{{ v.title | json }},"option1":{{ v.option1 | json }},"available":{{ v.available }}}{%- endfor -%}]}
      {%- assign pin_sep = ',' -%}
      {%- endif -%}

      {%- assign p = banner.pin_5_producto.value -%}
      {%- if p != blank -%}
      {{ pin_sep }}{"x":{{ banner.pin_5_pos_x.value | default: 65 }},"y":{{ banner.pin_5_pos_y.value | default: 70 }},"title":{{ p.title | json }},"price":{{ p.price | money | json }},"compare_price":{%- if p.compare_at_price > p.price -%}{{ p.compare_at_price | money | json }}{%- else -%}null{%- endif -%},"image":{%- if p.featured_image -%}{{ p.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},"alt":{{ p.featured_image.alt | default: p.title | json }},"url":{{ p.url | json }},"option_name":{{ p.options.first | json }},"variants":[{%- for v in p.variants -%}{%- unless forloop.first -%},{%- endunless -%}{"id":{{ v.id }},"title":{{ v.title | json }},"option1":{{ v.option1 | json }},"available":{{ v.available }}}{%- endfor -%}]}
      {%- endif -%}
    ]
  }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]
</script>
{%- endif -%}

<script>
(function () {
  console.log('[RompeGrid] script cargado — seccion {{ section.id }}');

  /* ── Helpers ─────────────────────────────────────────────────────────────── */

  function debounce(fn, ms) {
    var t;
    return function () { clearTimeout(t); t = setTimeout(fn, ms); };
  }

  function log(msg, data) {
    if (data !== undefined) { console.log('[RompeGrid] ' + msg, data); }
    else { console.log('[RompeGrid] ' + msg); }
  }
  function warn(msg, data) {
    if (data !== undefined) { console.warn('[RompeGrid] ' + msg, data); }
    else { console.warn('[RompeGrid] ' + msg); }
  }

  /* ── Leer datos ──────────────────────────────────────────────────────────── */

  var dataEl = document.getElementById('plp-rompe-grid-data-{{ section.id }}');
  var banners = [];
  if (!dataEl) {
    warn('Script <data> no encontrado → el metacampo custom.mox_plp_banners_rompegrids esta vacio o no asignado a esta coleccion');
  } else {
    try {
      banners = JSON.parse(dataEl.textContent) || [];
      log('Banners parseados del JSON:', banners);
    } catch (e) {
      warn('Error al parsear JSON de banners:', e, '\nContenido raw:', dataEl.textContent);
    }
  }

  /* ── Config sheet mobile ─────────────────────────────────────────────────── */

  var FINANCE_TEXT       = {{ section.settings.pin_finance_text | default: '' | json }};
  var FINANCE_LINK_LABEL = {{ section.settings.pin_finance_link_label | default: '' | json }};
  var FINANCE_LINK_URL   = {{ section.settings.pin_finance_link_url | default: '' | json }};
  var PIN_GIF_URL        = {{ section.settings.pin_gif_url | default: '' | json }};

  function isMobile() { return window.innerWidth <= 749; }

  /* ── Mobile bottom sheet ─────────────────────────────────────────────────── */

  function getOrCreateSheet() {
    var existing = document.getElementById('rompe-grid-sheet');
    if (existing) return existing;

    var overlay = document.createElement('div');
    overlay.id = 'rompe-grid-sheet-overlay';
    overlay.className = 'rompe-grid-sheet-overlay';
    overlay.addEventListener('click', closeSheet);
    document.body.appendChild(overlay);

    var el = document.createElement('div');
    el.id = 'rompe-grid-sheet';
    el.className = 'rompe-grid-sheet';
    el.innerHTML =
      /* MOXIE: misma estructura/clases (renombradas) que el drawer mobile de
         "Moxie Lookbook Advanced PRO" — ver sections/lookbook-featured.liquid,
         bloque `mobileHtml` (.lb-md-product / .lb-swatches-add-to-cart-btn). */
      '<button class="rompe-grid-sheet__close" type="button" aria-label="Cerrar">' +
        '<svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">' +
          '<path d="M0 11L4.29349 5.22741L0.399395 0H2.67927L5.52496 3.8965H5.59153L8.42058 0H10.5673L6.68986 5.21137L11 11H8.73676L5.49168 6.54227H5.39183L2.16339 11H0Z" fill="#2C2C2C"/>' +
        '</svg>' +
      '</button>' +
      '<div class="rompe-grid-sheet__body">' +
        '<div class="rompe-grid-sheet__row">' +
          '<img class="rompe-grid-sheet__img" src="" alt="" loading="eager">' +
          '<div class="rompe-grid-sheet__info">' +
            '<p class="rompe-grid-sheet__finance"></p>' +
            '<p class="rompe-grid-sheet__name"></p>' +
            '<div class="rompe-grid-sheet__prices">' +
              '<span class="rompe-grid-sheet__compare"></span>' +
              '<span class="rompe-grid-sheet__price"></span>' +
            '</div>' +
            '<div class="rompe-grid-sheet__size-section">' +
              '<div class="rompe-grid-sheet__variant-selector">' +
                '<label class="rompe-grid-sheet__size-label">Talla</label>' +
                '<select class="rompe-grid-sheet__select" aria-label="Talla"></select>' +
              '</div>' +
              '<button class="rompe-grid-sheet__atb" type="button">Añadir a la bolsa</button>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    document.body.appendChild(el);

    el.querySelector('.rompe-grid-sheet__close').addEventListener('click', closeSheet);
    el.querySelector('.rompe-grid-sheet__select').addEventListener('change', function () {
      updateSheetVariant(this.value);
    });
    el.querySelector('.rompe-grid-sheet__atb').addEventListener('click', sheetAddToCart);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeSheet();
    });

    return el;
  }

  function openSheet(pin) {
    var el      = getOrCreateSheet();
    var overlay = document.getElementById('rompe-grid-sheet-overlay');

    /* Imagen */
    var imgEl = el.querySelector('.rompe-grid-sheet__img');
    if (pin.image) {
      imgEl.src = pin.image;
      imgEl.alt = pin.alt || pin.title || '';
      imgEl.style.display = '';
    } else {
      imgEl.style.display = 'none';
    }

    /* Financiamiento */
    var financeEl = el.querySelector('.rompe-grid-sheet__finance');
    var financeHTML = '';
    if (FINANCE_TEXT)       financeHTML = FINANCE_TEXT;
    if (FINANCE_LINK_LABEL) {
      var href = FINANCE_LINK_URL || '#';
      financeHTML += (financeHTML ? ' ' : '') + '<a href="' + href + '">' + FINANCE_LINK_LABEL + '</a>';
    }
    if (financeHTML) {
      financeEl.innerHTML = financeHTML;
      financeEl.style.display = '';
    } else {
      financeEl.style.display = 'none';
    }

    /* Nombre */
    el.querySelector('.rompe-grid-sheet__name').textContent = pin.title || '';

    /* Precios */
    var cmpEl   = el.querySelector('.rompe-grid-sheet__compare');
    var priceEl = el.querySelector('.rompe-grid-sheet__price');
    if (pin.compare_price) {
      cmpEl.textContent  = pin.compare_price;
      cmpEl.style.display = '';
    } else {
      cmpEl.style.display = 'none';
    }
    priceEl.textContent = pin.price || '';

    /* Tallas — el botón de añadir a la bolsa siempre es visible; solo el
       selector de talla se oculta si no hay variantes reales (igual que
       Lookbook Advanced PRO). */
    var variantSelector = el.querySelector('.rompe-grid-sheet__variant-selector');
    var select          = el.querySelector('.rompe-grid-sheet__select');
    var atbBtn          = el.querySelector('.rompe-grid-sheet__atb');
    var hasRealVariants = pin.variants && pin.variants.length > 0 &&
      !(pin.variants.length === 1 && pin.variants[0].title === 'Default Title');

    if (hasRealVariants) {
      el.querySelector('.rompe-grid-sheet__size-label').textContent = pin.option_name || 'Talla';
      select.innerHTML = '';
      pin.variants.forEach(function (v) {
        var opt = document.createElement('option');
        opt.value = v.id;
        opt.textContent = v.option1 || v.title;
        if (!v.available) {
          opt.disabled = true;
          opt.textContent += ' – Agotado';
        }
        select.appendChild(opt);
      });
      variantSelector.style.display = '';
      atbBtn.dataset.variantId = select.value;
    } else {
      variantSelector.style.display = 'none';
      atbBtn.dataset.variantId = pin.variants && pin.variants[0] ? String(pin.variants[0].id) : '';
    }

    atbBtn.dataset.productUrl = pin.url || '';
    atbBtn.textContent        = 'Añadir a la bolsa';
    atbBtn.disabled           = false;
    atbBtn.classList.remove('is-loading', 'is-added');

    el.classList.add('is-open');
    if (overlay) overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    var el      = document.getElementById('rompe-grid-sheet');
    var overlay = document.getElementById('rompe-grid-sheet-overlay');
    if (el)      el.classList.remove('is-open');
    if (overlay) overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function updateSheetVariant(variantId) {
    var el = document.getElementById('rompe-grid-sheet');
    if (!el) return;
    var atbBtn = el.querySelector('.rompe-grid-sheet__atb');
    atbBtn.dataset.variantId = variantId;
    atbBtn.textContent = 'Añadir a la bolsa';
    atbBtn.disabled    = false;
  }

  function sheetAddToCart() {
    var el     = document.getElementById('rompe-grid-sheet');
    if (!el)   return;
    var btn        = el.querySelector('.rompe-grid-sheet__atb');
    var variantId  = btn.dataset.variantId;
    var productUrl = btn.dataset.productUrl;

    if (!variantId) {
      if (productUrl) window.location.href = productUrl;
      return;
    }

    btn.disabled    = true;
    btn.textContent = 'Agregando…';

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body:    JSON.stringify({ items: [{ id: parseInt(variantId, 10), quantity: 1 }] })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.status && data.status >= 400) {
        btn.disabled    = false;
        btn.textContent = data.description || 'Error — intentar de nuevo';
      } else {
        btn.textContent = '¡Añadido!';
        /* Notificar al tema para actualizar el mini-cart */
        try { document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true })); } catch (e) {}
        try { document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true })); } catch (e) {}
        setTimeout(closeSheet, 900);
      }
    })
    .catch(function () {
      btn.disabled    = false;
      btn.textContent = 'Error — intentar de nuevo';
    });
  }

  /* ── Crear elemento de pin ───────────────────────────────────────────────── */

  function createPinEl(pin, index) {
    var btn = document.createElement('button');
    btn.className = 'plp-rompe-grid__pin';
    btn.setAttribute('type', 'button');
    btn.setAttribute('aria-label', 'Ver producto: ' + (pin.title || ''));
    btn.setAttribute('data-pin', String(index));
    btn.style.left = pin.x + '%';
    btn.style.top  = pin.y + '%';

    /* Dot */
    var dot = document.createElement('span');
    dot.className = 'plp-rompe-grid__pin-dot';
    dot.setAttribute('aria-hidden', 'true');
    if (PIN_GIF_URL) {
      var dotImg = document.createElement('img');
      dotImg.className = 'plp-rompe-grid__pin-dot-img';
      dotImg.src = PIN_GIF_URL;
      dotImg.alt = '';
      dotImg.loading = 'lazy';
      dot.appendChild(dotImg);
    } else {
      dot.textContent = '+';
    }
    btn.appendChild(dot);

    /* Popup (desktop only) */
    var popup = document.createElement('div');
    popup.className = 'plp-rompe-grid__pin-popup';

    var card = document.createElement('a');
    card.href = pin.url || '#';
    card.className = 'plp-rompe-grid__pin-card';

    if (pin.image) {
      var imgWrap = document.createElement('div');
      imgWrap.className = 'plp-rompe-grid__pin-img-wrap';
      var img = document.createElement('img');
      img.src = pin.image;
      img.alt = pin.alt || pin.title || '';
      img.loading = 'lazy';
      img.className = 'plp-rompe-grid__pin-img';
      imgWrap.appendChild(img);
      card.appendChild(imgWrap);
    }

    var info = document.createElement('div');
    info.className = 'plp-rompe-grid__pin-info';

    var name = document.createElement('p');
    name.className = 'plp-rompe-grid__pin-name';
    name.textContent = pin.title || '';
    info.appendChild(name);

    var prices = document.createElement('div');
    prices.className = 'plp-rompe-grid__pin-prices';

    if (pin.compare_price) {
      var cmp = document.createElement('span');
      cmp.className = 'plp-rompe-grid__pin-compare';
      cmp.textContent = pin.compare_price;
      prices.appendChild(cmp);
    }

    var price = document.createElement('span');
    price.className = 'plp-rompe-grid__pin-price';
    price.textContent = pin.price || '';
    prices.appendChild(price);

    info.appendChild(prices);
    card.appendChild(info);
    popup.appendChild(card);
    btn.appendChild(popup);

    return btn;
  }

  /* ── Gestión global de pines abiertos ────────────────────────────────────── */

  if (!window._rompeGridPinInit) {
    window._rompeGridPinInit = true;

    document.addEventListener('click', function (e) {
      if (!e.target.closest('.plp-rompe-grid__pin')) {
        document.querySelectorAll('.plp-rompe-grid__pin.is-open')
          .forEach(function (p) { p.classList.remove('is-open'); });
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.plp-rompe-grid__pin.is-open')
          .forEach(function (p) { p.classList.remove('is-open'); });
      }
    });
  }

  function setupPinToggle(bannerEl, pins) {
    bannerEl.querySelectorAll('.plp-rompe-grid__pin').forEach(function (pin) {
      var pinIndex = parseInt(pin.getAttribute('data-pin'), 10) || 0;
      var pinData  = (pins && pins[pinIndex]) || null;

      pin.addEventListener('click', function (e) {
        e.stopPropagation();

        if (isMobile()) {
          /* En mobile: no abrir popup inline, abrir el bottom sheet */
          bannerEl.querySelectorAll('.plp-rompe-grid__pin.is-open')
            .forEach(function (p) { p.classList.remove('is-open'); });
          if (pinData) openSheet(pinData);
          return;
        }

        /* Desktop: toggle popup inline */
        var isOpen = pin.classList.contains('is-open');
        bannerEl.querySelectorAll('.plp-rompe-grid__pin.is-open')
          .forEach(function (p) { p.classList.remove('is-open'); });
        if (!isOpen) pin.classList.add('is-open');
      });
    });

    /* Evitar que clicks en el popup cierren el pin */
    bannerEl.querySelectorAll('.plp-rompe-grid__pin-popup').forEach(function (popup) {
      popup.addEventListener('click', function (e) { e.stopPropagation(); });
    });
  }

  /* ── Crear elemento de banner ────────────────────────────────────────────── */

  function createBannerEl(banner) {
    var colSpan  = parseInt(banner.columnas, 10) || 2;
    var hasPins  = Array.isArray(banner.pins) && banner.pins.length > 0;

    var li = document.createElement('li');
    li.className = 'product-grid__item plp-rompe-grid plp-rompe-grid--span-' + colSpan +
      (hasPins ? ' plp-rompe-grid--has-pins' : ' plp-rompe-grid--no-pins');
    li.setAttribute('role', 'listitem');

    if (banner.bg_color)   li.style.backgroundColor = banner.bg_color;
    if (banner.text_color) li.style.color = banner.text_color;

    /*
     * Si el banner tiene pines el wrapper es siempre <div> para evitar
     * anidar <a> dentro de <a> (popup card vs banner link).
     * Sin pines, el banner completo es clickeable si tiene url_del_banner.
     */
    var hasBannerUrl   = banner.url_del_banner && banner.url_del_banner.length > 0;
    var hasWrapperLink = !hasPins && hasBannerUrl;
    var inner = document.createElement(hasWrapperLink ? 'a' : 'div');
    inner.className = 'plp-rompe-grid__inner';
    if (hasWrapperLink) {
      inner.href = banner.url_del_banner;
      inner.target = '_blank';
      inner.rel = 'noopener';
    }

    /*
     * Con pines el wrapper no puede ser <a>, así que si hay url_del_banner
     * se navega manualmente al hacer click, salvo que el click venga de un
     * pin o de un enlace real (botón, tarjeta del popup).
     */
    if (hasPins && hasBannerUrl) {
      inner.classList.add('plp-rompe-grid__inner--clickable');
      inner.addEventListener('click', function (e) {
        if (e.target.closest('.plp-rompe-grid__pin') || e.target.closest('a')) return;
        window.open(banner.url_del_banner, '_blank', 'noopener');
      });
    }

    /* Imagen de fondo */
    if (banner.imagen) {
      var media = document.createElement('div');
      media.className = 'plp-rompe-grid__media';
      var img = document.createElement('img');
      img.src = banner.imagen;
      img.alt = banner.imagen_alt || banner.titulo || '';
      img.loading = 'lazy';
      img.className = 'plp-rompe-grid__img';
      media.appendChild(img);
      inner.appendChild(media);
    }

    /* Contenido de texto */
    if (banner.titulo || banner.descripcion || banner.texto_boton) {
      var content = document.createElement('div');
      content.className = 'plp-rompe-grid__content';

      if (banner.titulo) {
        var h = document.createElement('p');
        h.className = 'plp-rompe-grid__title';
        h.textContent = banner.titulo;
        content.appendChild(h);
      }

      if (banner.descripcion) {
        var d = document.createElement('p');
        d.className = 'plp-rompe-grid__desc';
        d.textContent = banner.descripcion;
        content.appendChild(d);
      }

      if (banner.texto_boton) {
        if (!hasWrapperLink && banner.url_boton) {
          /* El wrapper no es <a>: el botón necesita su propio enlace real */
          var btnA = document.createElement('a');
          btnA.className = 'plp-rompe-grid__btn';
          btnA.href = banner.url_boton;
          btnA.textContent = banner.texto_boton;
          content.appendChild(btnA);
        } else {
          var btnSpan = document.createElement('span');
          btnSpan.className = 'plp-rompe-grid__btn';
          btnSpan.textContent = banner.texto_boton;
          content.appendChild(btnSpan);
        }
      }

      inner.appendChild(content);
    }

    /* Pines */
    if (hasPins) {
      banner.pins.forEach(function (pin, index) {
        inner.appendChild(createPinEl(pin, index));
      });
    }

    li.appendChild(inner);

    if (hasPins) setupPinToggle(li, banner.pins);

    return li;
  }

  /* ── Inyectar banners en el grid ─────────────────────────────────────────── */

  function injectBanners() {
    log('--- injectBanners() ---');

    var grid = document.querySelector('.product-grid[data-testid="product-grid"]');
    if (!grid) {
      warn('Grid no encontrado: .product-grid[data-testid="product-grid"]');
      return;
    }
    log('Grid encontrado:', grid);

    grid.querySelectorAll('.plp-rompe-grid').forEach(function (el) { el.remove(); });

    if (!banners.length) {
      warn('banners[] esta vacio — no hay nada que inyectar');
      return;
    }

    var visible = banners
      .sort(function (a, b) { return b.posicion - a.posicion; });

    if (!visible.length) {
      warn('Ningun banner activo encontrado — revisa los metaobjetos de esta coleccion');
      return;
    }
    log('Banners visibles:', visible);

    var items = Array.from(
      grid.querySelectorAll('.product-grid__item:not(.plp-rompe-grid)')
    );
    log('Productos en grid:', items.length);
    if (!items.length) {
      warn('No se encontraron .product-grid__item en el grid');
      return;
    }

    visible.forEach(function (banner) {
      var pos      = Math.max(parseInt(banner.posicion, 10) || 1, 1);
      var bannerEl = createBannerEl(banner);

      if (pos <= 1) {
        log('Insertando banner "' + banner.titulo + '" ANTES del item 0 (posicion 1)');
        if (items[0]) items[0].before(bannerEl);
      } else {
        var idx   = Math.min(pos - 2, items.length - 1);
        var refEl = items[idx];
        log('Insertando banner "' + banner.titulo + '" en posicion=' + pos + ' (despues de item idx=' + idx + ')', refEl);
        if (refEl) refEl.after(bannerEl);
      }
    });

    log('Inyeccion completada');
  }

  /* ── Observar el grid para infinite scroll / filtros ─────────────────────── */

  function observeGrid() {
    var grid = document.querySelector('.product-grid[data-testid="product-grid"]');
    if (!grid || grid._rompeObserver) return;

    var debouncedInject = debounce(injectBanners, 300);

    grid._rompeObserver = new MutationObserver(function (mutations) {
      var hasNewRealItems = mutations.some(function (m) {
        return Array.from(m.addedNodes).some(function (n) {
          return n.nodeType === 1
            && n.classList.contains('product-grid__item')
            && !n.classList.contains('plp-rompe-grid');
        });
      });
      if (hasNewRealItems) debouncedInject();
    });

    grid._rompeObserver.observe(grid, { childList: true });
  }

  /* ── Inicializacion ──────────────────────────────────────────────────────── */

  function init() {
    injectBanners();
    observeGrid();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      injectBanners();
      observeGrid();
    }
  });

})();
</script>

