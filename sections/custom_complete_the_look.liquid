<script
  src="{{ 'custom-complete-the-look.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div class="custom-complete-the-look-mox custom-center-container"{% if section.settings.enable_stacking %} data-stacking="overlay"{% endif %}>
<complete-the-look-carousel
  class="
  custom-standar-max-width
    section
    section--{{ section.settings.section_width }}
    section-complete-the-look
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    --ctl-duration: {{ section.settings.scroll_speed }}s;
    --ctl-item-width: {{ section.settings.item_width }}px;
    --ctl-gap: {{ section.settings.item_gap }}px;
  "
>
  {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
    <div class="ctl-header">
      {%- if section.settings.title != blank -%}
        <h2 class="ctl-header__title h2">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ctl-header__subtitle paragraph">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ctl-track-wrapper">
    <div class="ctl-track" ref="track">
      {%- comment -%} Each block renders a complete-the-look-item element {%- endcomment -%}
      {% content_for 'blocks' %}
    </div>
  </div>
</complete-the-look-carousel>
</div>

{% schema %}
{
  "name": "Moxie Complete the Look",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_custom_complete_the_look_item"
    },
    { "type": "@theme" }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Compra tu look"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descubre los productos de cada look"
    },
    {
      "type": "header",
      "content": "Carrusel"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Velocidad (segundos por ciclo)",
      "min": 10,
      "max": 120,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "item_width",
      "label": "Ancho del ítem (px)",
      "min": 160,
      "max": 480,
      "step": 8,
      "default": 280
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Espacio entre ítems (px)",
      "min": 0,
      "max": 64,
      "step": 4,
      "default": 0
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de sección",
      "options": [
        { "value": "full-width", "label": "Completo" },
        { "value": "page-width", "label": "Contenido" }
      ],
      "default": "full-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Espaciado superior",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Espaciado inferior",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Apilamiento sticky"
    },
    {
      "type": "checkbox",
      "id": "enable_stacking",
      "label": "Activar apilamiento sobre sección anterior",
      "info": "Desliza esta sección sobre el Hero sticky. Requiere que el apilamiento esté activo también en Moxie Hero.",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Moxie Complete the Look",
      "category": "Moxie",
      "blocks": {
        "item-1": { "type": "_custom_complete_the_look_item" },
        "item-2": { "type": "_custom_complete_the_look_item" },
        "item-3": { "type": "_custom_complete_the_look_item" },
        "item-4": { "type": "_custom_complete_the_look_item" },
        "item-5": { "type": "_custom_complete_the_look_item" }
      },
      "block_order": ["item-1", "item-2", "item-3", "item-4", "item-5"]
    }
  ]
}
{% endschema %}
