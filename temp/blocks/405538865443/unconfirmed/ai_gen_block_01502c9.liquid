{% doc %}
  @prompt
    Creáme un bloque que tenga una imagen a la derecha y un producto izquierda
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-image-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-image-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: center;
    flex-direction: row;
  }

  .ai-product-section-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-image-section-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
    min-height: 300px;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-product-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-product-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-product-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-image-container-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<product-image-block-{{ ai_gen_id }}
  class="ai-product-image-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-image-container-{{ ai_gen_id }}">
    <div class="ai-product-section-{{ ai_gen_id }}">
      {% if block.settings.product %}
        <h2 class="ai-product-title-{{ ai_gen_id }}">{{ block.settings.product.title }}</h2>
        
        {% if block.settings.product.description != blank %}
          <div class="ai-product-description-{{ ai_gen_id }}">
            {{ block.settings.product.description | truncate: 200 }}
          </div>
        {% endif %}

        <div class="ai-product-price-{{ ai_gen_id }}">
          {{ block.settings.product.price | money }}
        </div>

        {% if block.settings.show_button %}
          <a
            href="{{ block.settings.product.url }}"
            class="ai-product-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      {% else %}
        <h2 class="ai-product-title-{{ ai_gen_id }}">Nombre del producto</h2>
        <div class="ai-product-description-{{ ai_gen_id }}">
          Selecciona un producto para mostrar su información aquí. La descripción del producto aparecerá en este espacio.
        </div>
        <div class="ai-product-price-{{ ai_gen_id }}">$0.00</div>
        {% if block.settings.show_button %}
          <a href="#" class="ai-product-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      {% endif %}
    </div>

    <div class="ai-image-section-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-product-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-product-empty-state-{{ ai_gen_id }}">
            Agrega una imagen
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</product-image-block-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductImageBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-image-block-{{ ai_gen_id }}', ProductImageBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Producto con imagen",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Producto"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Producto"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Radio de borde de imagen",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre elementos",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Botón"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Mostrar botón",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Ver producto"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Color de fondo del botón",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Color de fondo al pasar el cursor",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Color del texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Radio de borde del botón",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Estilo de texto"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Tamaño de la descripción",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Tamaño del precio",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Producto con imagen"
    }
  ]
}
{% endschema %}
