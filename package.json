{
  "name": "americanino-ec-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sass:watch": "sass src/scss/main.scss assets/moxie.css --watch --style=expanded --embed-source-map",
    "win:sass:watch": "cross-env sass src/scss/main.scss assets/moxie.css --watch --style=expanded --embed-source-map",
    "sass:build": "sass src/scss/main.scss assets/moxie.css --style=compressed --no-source-map",
    "win:sass:build": "cross-env sass src/scss/main.scss assets/moxie.css --style=compressed --no-source-map",
    "theme:dev": "shopify theme dev --store=americanino-ec",
    "dev:shopify": "npm-run-all --parallel sass:watch theme:dev",
    "win:dev:shopify": "npm-run-all --parallel win:sass:watch theme:dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "npm-run-all": "^4.1.5",
    "sass": "^1.83.0"
  }
}
