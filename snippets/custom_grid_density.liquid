{%- doc -%}
  MOXIE: Selector de densidad de columnas personalizado
  Reemplaza grid-density-controls con opciones por número exacto de columnas
  y control independiente de viewport.

  @param {string} viewport - 'desktop' | 'mobile'
  @param {boolean} show_desktop - Mostrar en desktop
  @param {boolean} show_mobile - Mostrar en mobile
{%- enddoc -%}

{%- liquid
  assign show_desktop = show_desktop | default: true
  assign show_mobile = show_mobile | default: true
-%}

<div class="moxie-grid-density{% unless show_desktop %} moxie-grid-density--hide-desktop{% endunless %}{% unless show_mobile %} moxie-grid-density--hide-mobile{% endunless %}">
  <fieldset class="moxie-grid-density__options">
    <legend class="visually-hidden">Columnas por fila</legend>

    {%- if viewport == 'desktop' -%}
      <label class="moxie-grid-density__option">
        <input
          type="radio"
          name="grid"
          value="list-2"
          class="column-options__option-input"
          aria-label="2 productos en lista"
          on:change="results-list/updateLayout"
          data-skip-node-update
        >
        <span class="moxie-grid-density__label">
          <svg width="18" height="12" viewBox="0 0 18 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="2.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="2.5" cy="9.5" r="2.5" fill="currentColor"/>
            <path d="M7 2.5H18" stroke="currentColor" stroke-width="1.2"/>
            <path d="M7 10H18" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </span>
      </label>

      <label class="moxie-grid-density__option">
        <input
          type="radio"
          name="grid"
          value="col-2"
          class="column-options__option-input"
          aria-label="2 productos en card"
          on:change="results-list/updateLayout"
          data-skip-node-update
        >
        <span class="moxie-grid-density__label">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="2.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="2.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="9.5" r="2.5" fill="currentColor"/>
          </svg>
        </span>
      </label>

      <label class="moxie-grid-density__option">
        <input
          type="radio"
          name="grid"
          value="col-3"
          class="column-options__option-input"
          aria-label="3 productos en card"
          on:change="results-list/updateLayout"
          data-skip-node-update
        >
        <span class="moxie-grid-density__label">
          <svg width="19" height="12" viewBox="0 0 19 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="2.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="16.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="2.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="16.5" cy="9.5" r="2.5" fill="currentColor"/>
          </svg>
        </span>
      </label>

      <label class="moxie-grid-density__option">
        <input
          type="radio"
          name="grid"
          value="col-4"
          class="column-options__option-input"
          aria-label="4 productos en card"
          checked
          data-grid-layout="desktop-default-option"
          on:change="results-list/updateLayout"
          data-skip-node-update
        >
        <span class="moxie-grid-density__label">
          <svg width="26" height="12" viewBox="0 0 26 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="2.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="16.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="23.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="16.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="2.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="23.5" cy="9.5" r="2.5" fill="currentColor"/>
          </svg>
        </span>
      </label>

    {%- elsif viewport == 'mobile' -%}
      <label class="moxie-grid-density__option">
        <input
          type="radio"
          name="grid-mobile"
          value="list-2"
          class="column-options__option-input"
          aria-label="1 producto en lista"
          on:change="results-list/updateLayout"
        >
        <span class="moxie-grid-density__label">
           <svg width="18" height="12" viewBox="0 0 18 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="2.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="2.5" cy="9.5" r="2.5" fill="currentColor"/>
            <path d="M7 2.5H18" stroke="currentColor" stroke-width="1.2"/>
            <path d="M7 10H18" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </span>
      </label>

      <label class="moxie-grid-density__option">
        <input
          type="radio"
          name="grid-mobile"
          value="col-2"
          class="column-options__option-input"
          aria-label="2 productos en card"
          checked
          data-grid-layout="mobile-option"
          on:change="results-list/updateLayout"
        >
        <span class="moxie-grid-density__label">
           <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="2.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="2.5" cy="9.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="2.5" r="2.5" fill="currentColor"/>
            <circle cx="9.5" cy="9.5" r="2.5" fill="currentColor"/>
          </svg>
        </span>
      </label>
    {%- endif -%}
  </fieldset>
</div>

{% stylesheet %}

{% endstylesheet %}
