{%- comment -%}
  MOXIE: Descuento Extra — línea de precio "Extra: $XX"

  Busca el metaobject descuento_extra activo, verifica scope
  y aplica visibilidad de marca via data-brand-show (CSS-driven,
  ya que la marca activa vive en localStorage, no en Liquid).

  @param {product} product      — producto a evaluar
  @param {integer} [base_price] — precio base en centavos (default: product.price)
{%- endcomment -%}

{%- liquid
  assign mox_show = false

  comment
    ── 1. Buscar el metaobject activo ──────────────────────────
  endcomment
  for d in shop.metaobjects.descuento_extra.values
    if d.active.value == true
      assign mox_d = d
      assign mox_show = true
      break
    endif
  endfor

 
  if mox_show
    assign mox_brand_visibility = mox_d.donde_mostrar.value | default: 'all' | downcase | strip

    unless mox_brand_visibility == 'all' or mox_brand_visibility == 'mic' or mox_brand_visibility == 'little-mic'
      assign mox_brand_visibility = 'all'
    endunless
  endif

  comment
    ── 3. Validar scope (colección / all) ──────────────────────
    Soporta scope como single_line_text_field (handle string)
    o como collection_reference (objeto con .handle).
    Fail-safe: scope vacío → no mostrar.

    Shopify no garantiza product.collections en todos los contextos
    (cards de sección, search, etc.), por eso se usan dos métodos:
      Método A — product.collections  (PDP, páginas de colección)
      Método B — collections[handle]  (fallback para el resto;
                  aplica solo los primeros ~20 productos de la col.)
  endcomment
  if mox_show and product
    assign mox_scope_raw = mox_d.scope.value

    if mox_scope_raw.handle != blank
      assign mox_scope = mox_scope_raw.handle | downcase | strip
    else
      assign mox_scope = mox_scope_raw | downcase | strip
    endif

    if mox_scope == blank
      assign mox_show = false

    elsif mox_scope != 'all'
      assign mox_show = false

   
      for col in product.collections
        if col.handle == mox_scope
          assign mox_show = true
          break
        endif
      endfor

    
      unless mox_show
        for p in collections[mox_scope].products
          if p.id == product.id
            assign mox_show = true
            break
          endif
        endfor
      endunless
    endif
  endif

  if mox_show
    assign mox_pct    = mox_d.discount_pct.value | times: 1
    assign mox_base   = base_price | default: product.price
    assign mox_saving = mox_base | times: mox_pct | divided_by: 100
    assign mox_final  = mox_base | minus: mox_saving
  endif
-%}

{%- if mox_show -%}
  <div
    class="mox-extra-price"
    data-brand-show="{{ mox_brand_visibility }}"
    style="--mox-extra-color: {{ mox_d.badge_color.value | default: '#e63946' }};"
  >
    <span class="mox-extra-price__label">Extra:</span>
    <span class="mox-extra-price__value">{{ mox_final | money }}</span>
  </div>
{%- endif -%}
