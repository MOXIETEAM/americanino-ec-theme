{%- comment -%}
  MOXIE: BreadcrumbList JSON-LD global, requerido por el brief de datos
  estructurados del cliente. Se renderiza una vez por página desde
  layout/theme.liquid, basado en `request.page_type`.

  No sustituye el breadcrumb visual (custom_breadcrumb.liquid /
  custom_pdp_breadcrumb.liquid), que sigue gestionando la jerarquía visible
  vía los metafields custom.linea / custom.categoria. Este bloque es solo
  para SEO y usa collection/blog/article/page nativos de Shopify.
{%- endcomment -%}

<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'accessibility.home' | t | json }},
      "item": {{ shop.url | json }}
    }
    {%- if request.page_type == 'product' -%}
      {%- if collection -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ shop.url | append: collection.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ product.title | json }},
          "item": {{ shop.url | append: product.url | json }}
        }
      {%- else -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ product.title | json }},
          "item": {{ shop.url | append: product.url | json }}
        }
      {%- endif -%}
    {%- elsif request.page_type == 'collection' and collection.handle -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ shop.url | append: collection.url | json }}
      }
    {%- elsif request.page_type == 'blog' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ shop.url | append: blog.url | json }}
      }
    {%- elsif request.page_type == 'article' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ shop.url | append: blog.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ article.title | json }},
        "item": {{ shop.url | append: article.url | json }}
      }
    {%- elsif request.page_type == 'page' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ shop.url | append: page.url | json }}
      }
    {%- endif -%}
  ]
}
</script>
