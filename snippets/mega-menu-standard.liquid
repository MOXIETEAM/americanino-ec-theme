{%- comment -%}
  mega-menu-standard.liquid — Layout Americanino
  3 zonas: LEFT (featured links) | CENTER (category columns) | RIGHT (promo image)

  Regla para separar zonas a partir del menú de navegación:
    • 2do nivel SIN hijos  → featured (columna izquierda, texto grande)
    • 2do nivel CON hijos  → columna de categoría (centro)

  @param link         {link}        Ítem de 1er nivel del menú
  @param panel_promo  {metaobject}  Metaobject megamenu_panel (puede ser blank)
{%- endcomment -%}

{%- assign panel_key = link.title | handleize -%}

{%- comment -%} Detectar si existen featured links (sin hijos) {%- endcomment -%}
{%- assign has_featured = false -%}
{%- for fl in link.links -%}
  {%- if fl.links.size == 0 -%}
    {%- assign has_featured = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Detectar si existe una imagen promo válida {%- endcomment -%}
{%- assign has_promo = false -%}
{%- if panel_promo != blank -%}
  {%- if panel_promo.imagen_promo.value != blank -%}
    {%- assign has_promo = true -%}
  {%- endif -%}
{%- endif -%}

<div
  class="moxie-mega__panel moxie-mega__panel--americanino"
  data-panel="{{ panel_key }}"
  role="region"
  aria-label="{{ link.title }}"
>
  <div class="moxie-mega__panel-inner{% if has_promo %} moxie-mega__panel-inner--with-promo{% endif %}">

    {%- comment -%} ── ZONA IZQUIERDA: links sin hijos (featured) ── {%- endcomment -%}
    {%- if has_featured -%}
      <div class="moxie-mega__featured">
        {%- for fl in link.links -%}
          {%- if fl.links.size == 0 -%}
            <a
              href="{{ fl.url }}"
              class="moxie-mega__featured-link{% if fl.current %} moxie-mega__featured-link--active{% endif %}"
              {% if fl.current %}aria-current="page"{% endif %}
            >
              {{- fl.title -}}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="moxie-mega__v-divider" aria-hidden="true"></div>
    {%- endif -%}

    {%- comment -%} ── ZONA CENTRAL: columnas de categorías (con hijos) ── {%- endcomment -%}
    <div class="moxie-mega__columns">
      {%- for cat in link.links -%}
        {%- if cat.links.size > 0 -%}
          <div
            class="moxie-mega__catgroup"
            data-cat="{{ cat.title | handleize }}"
            role="group"
          >
            <a href="{{ cat.url }}" class="moxie-mega__cat-title">{{ cat.title }}</a>
            <ul class="moxie-mega__sublinks list-unstyled">
              {%- for sub in cat.links -%}
                <li>
                  <a
                    href="{{ sub.url }}"
                    class="moxie-mega__sublink{% if sub.current %} moxie-mega__sublink--active{% endif %}"
                    {% if sub.current %}aria-current="page"{% endif %}
                  >
                    {{- sub.title -}}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── ZONA DERECHA: imagen promo + CTA ── {%- endcomment -%}
    {%- if has_promo -%}
      {%- assign promo_img   = panel_promo.imagen_promo.value -%}
      {%- assign promo_href  = panel_promo.ver_todo_enlace.value | default: link.url -%}
      {%- assign promo_texto = panel_promo.ver_todo_texto.value | default: 'Ver todo' -%}

      <div class="moxie-mega__promo">
        <a
          href="{{ promo_href }}"
          class="moxie-mega__promo-img-wrap"
          tabindex="-1"
          aria-hidden="true"
        >
          {{- promo_img
            | image_url: width: 480
            | image_tag:
              loading: 'eager',
              class: 'moxie-mega__promo-img',
              alt: link.title,
              widths: '320, 480',
              sizes: '(min-width: 1200px) 480px, 320px'
          -}}
        </a>
        <a href="{{ promo_href }}" class="moxie-mega__promo-cta">
          {{- promo_texto -}}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>
